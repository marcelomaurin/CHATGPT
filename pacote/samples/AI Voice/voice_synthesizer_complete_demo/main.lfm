object frmMain: TfrmMain
  Left = 300
  Height = 600
  Top = 150
  Width = 800
  Caption = 'Voice Synthesizer Complete Demo - Local and OpenAI Voice API'
  ClientHeight = 600
  ClientWidth = 800
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  LCLVersion = '3.0.0.3'
  object pnlTop: TPanel
    Left = 0
    Height = 100
    Top = 0
    Width = 800
    Align = alTop
    ClientHeight = 100
    ClientWidth = 800
    TabOrder = 0
    object lblTitle: TLabel
      Left = 15
      Height = 25
      Top = 15
      Width = 286
      Caption = 'Voice Synthesizer Complete Demo'
      Font.Height = -18
      Font.Name = 'Segoe UI'
      Font.Style = [fsBold]
      ParentColor = False
    end
    object lblSubtitle: TLabel
      Left = 15
      Height = 15
      Top = 45
      Width = 431
      Caption = 'Generate real speech using local system voices or the OpenAI Voice API.'
      ParentColor = False
    end
    object lblStatus: TLabel
      Left = 15
      Height = 15
      Top = 70
      Width = 71
      Caption = 'Status: Ready'
      Font.Style = [fsBold]
      ParentColor = False
    end
  end
  object pgcMain: TPageControl
    Left = 10
    Height = 480
    Top = 110
    Width = 780
    ActivePage = tsConfiguration
    Align = alClient
    BorderSpacing.Around = 10
    TabIndex = 0
    TabOrder = 1
    object tsConfiguration: TTabSheet
      Caption = 'Configuration'
      ClientHeight = 452
      ClientWidth = 772
      object lblEngine: TLabel
        Left = 20
        Height = 15
        Top = 20
        Width = 82
        Caption = 'Speech engine:'
        ParentColor = False
      end
      object cbSpeechEngine: TComboBox
        Left = 150
        Height = 23
        Top = 16
        Width = 300
        ItemHeight = 15
        Style = csDropDownList
        TabOrder = 0
      end
      object lblToken: TLabel
        Left = 20
        Height = 15
        Top = 60
        Width = 53
        Caption = 'API token:'
        ParentColor = False
      end
      object edtOpenAIToken: TEdit
        Left = 150
        Height = 23
        Top = 56
        Width = 300
        EchoMode = emPassword
        PasswordChar = '*'
        TabOrder = 1
      end
      object lblModel: TLabel
        Left = 20
        Height = 15
        Top = 100
        Width = 78
        Caption = 'OpenAI model:'
        ParentColor = False
      end
      object cbOpenAIModel: TComboBox
        Left = 150
        Height = 23
        Top = 96
        Width = 300
        ItemHeight = 15
        Style = csDropDownList
        TabOrder = 2
      end
      object lblVoice: TLabel
        Left = 20
        Height = 15
        Top = 140
        Width = 74
        Caption = 'OpenAI voice:'
        ParentColor = False
      end
      object cbOpenAIVoice: TComboBox
        Left = 150
        Height = 23
        Top = 136
        Width = 300
        ItemHeight = 15
        Style = csDropDownList
        TabOrder = 3
      end
      object lblLanguage: TLabel
        Left = 20
        Height = 15
        Top = 180
        Width = 55
        Caption = 'Language:'
        ParentColor = False
      end
      object cbLanguage: TComboBox
        Left = 150
        Height = 23
        Top = 176
        Width = 300
        ItemHeight = 15
        Style = csDropDownList
        TabOrder = 4
      end
      object lblFormat: TLabel
        Left = 20
        Height = 15
        Top = 220
        Width = 80
        Caption = 'Output format:'
        ParentColor = False
      end
      object cbOutputFormat: TComboBox
        Left = 150
        Height = 23
        Top = 216
        Width = 300
        ItemHeight = 15
        Style = csDropDownList
        TabOrder = 5
      end
      object lblSpeed: TLabel
        Left = 20
        Height = 15
        Top = 260
        Width = 35
        Caption = 'Speed:'
        ParentColor = False
      end
      object edtSpeed: TEdit
        Left = 150
        Height = 23
        Top = 256
        Width = 300
        TabOrder = 6
        Text = '1.0'
      end
      object lblOutputFile: TLabel
        Left = 20
        Height = 15
        Top = 300
        Width = 60
        Caption = 'Output file:'
        ParentColor = False
      end
      object edtOutputFile: TEdit
        Left = 150
        Height = 23
        Top = 296
        Width = 400
        TabOrder = 7
        Text = 'output/speech.mp3'
      end
      object btnSelectOutputFile: TButton
        Left = 560
        Height = 25
        Top = 295
        Width = 150
        Caption = 'Select Output File'
        OnClick = btnSelectOutputFileClick
        TabOrder = 8
      end
      object btnApplyConfig: TButton
        Left = 150
        Height = 35
        Top = 350
        Width = 150
        Caption = 'Apply Configuration'
        OnClick = btnApplyConfigClick
        TabOrder = 9
      end
      object btnTestConfig: TButton
        Left = 310
        Height = 35
        Top = 350
        Width = 150
        Caption = 'Test Configuration'
        OnClick = btnTestConfigClick
        TabOrder = 10
      end
    end
    object tsSpeech: TTabSheet
      Caption = 'Speech'
      ClientHeight = 452
      ClientWidth = 772
      TabOrder = 1
      object lblSpeechText: TLabel
        Left = 15
        Height = 15
        Top = 15
        Width = 103
        Caption = 'Text to synthesize:'
        ParentColor = False
      end
      object memoSpeechText: TMemo
        Left = 15
        Height = 220
        Top = 40
        Width = 740
        ScrollBars = ssAutoBoth
        TabOrder = 0
      end
      object btnGenerateSpeech: TButton
        Left = 15
        Height = 35
        Top = 280
        Width = 180
        Caption = 'Generate Speech'
        OnClick = btnGenerateSpeechClick
        TabOrder = 1
      end
      object btnClearText: TButton
        Left = 210
        Height = 35
        Top = 280
        Width = 120
        Caption = 'Clear Text'
        OnClick = btnClearTextClick
        TabOrder = 2
      end
      object btnLoadExample: TButton
        Left = 340
        Height = 35
        Top = 280
        Width = 120
        Caption = 'Load Example'
        OnClick = btnLoadExampleClick
        TabOrder = 3
      end
    end
    object tsOutput: TTabSheet
      Caption = 'Output'
      ClientHeight = 452
      ClientWidth = 772
      TabOrder = 2
      object lblGeneratedFile: TLabel
        Left = 15
        Height = 15
        Top = 15
        Width = 111
        Caption = 'Generated audio file:'
        ParentColor = False
      end
      object edtGeneratedFile: TEdit
        Left = 15
        Height = 23
        Top = 40
        Width = 550
        ReadOnly = True
        TabOrder = 0
      end
      object btnPlayAudio: TButton
        Left = 15
        Height = 30
        Top = 80
        Width = 120
        Caption = 'Play Audio'
        OnClick = btnPlayAudioClick
        TabOrder = 1
      end
      object btnOpenOutputFolder: TButton
        Left = 145
        Height = 30
        Top = 80
        Width = 150
        Caption = 'Open Output Folder'
        OnClick = btnOpenOutputFolderClick
        TabOrder = 2
      end
      object btnCopyPath: TButton
        Left = 305
        Height = 30
        Top = 80
        Width = 120
        Caption = 'Copy Path'
        OnClick = btnCopyPathClick
        TabOrder = 3
      end
      object lblLastResult: TLabel
        Left = 15
        Height = 15
        Top = 130
        Width = 58
        Caption = 'Last result:'
        ParentColor = False
      end
      object memoLastResult: TMemo
        Left = 15
        Height = 180
        Top = 155
        Width = 740
        ReadOnly = True
        ScrollBars = ssAutoBoth
        TabOrder = 4
      end
    end
    object tsLog: TTabSheet
      Caption = 'Log'
      ClientHeight = 452
      ClientWidth = 772
      TabOrder = 3
      object memoLog: TMemo
        Left = 0
        Height = 402
        Top = 0
        Width = 772
        Align = alClient
        ScrollBars = ssAutoBoth
        TabOrder = 0
      end
      object pnlLogButtons: TPanel
        Left = 0
        Height = 50
        Top = 402
        Width = 772
        Align = alBottom
        ClientHeight = 50
        ClientWidth = 772
        TabOrder = 1
        object btnClearLog: TButton
          Left = 15
          Height = 30
          Top = 10
          Width = 120
          Caption = 'Clear Log'
          OnClick = btnClearLogClick
          TabOrder = 0
        end
      end
    end
  end
  object dlgSaveAudio: TSaveDialog
    Title = 'Select Output File'
    DefaultExt = '.mp3'
    Filter = 'MP3 Audio (*.mp3)|*.mp3|WAV Audio (*.wav)|*.wav|All files (*.*)|*.*'
    Left = 600
    Top = 380
  end
end
