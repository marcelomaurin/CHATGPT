object frmMain: TfrmMain
  Left = 300
  Height = 600
  Top = 150
  Width = 800
  Caption = 'Voice Synthesizer Complete Demo'
  ClientHeight = 600
  ClientWidth = 800
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  LCLVersion = '3.0.0.3'
  object pgcMain: TPageControl
    Left = 10
    Height = 580
    Top = 10
    Width = 780
    ActivePage = tsConfiguration
    Align = alClient
    BorderSpacing.Around = 10
    TabIndex = 0
    TabOrder = 0
    object tsConfiguration: TTabSheet
      Caption = 'Configuration'
      ClientHeight = 552
      ClientWidth = 772
      object lblEngine: TLabel
        Left = 20
        Height = 15
        Top = 20
        Width = 82
        Caption = 'Speech engine:'
        ParentColor = False
      end
      object cbSpeechEngine: TComboBox
        Left = 150
        Height = 23
        Top = 16
        Width = 300
        ItemHeight = 15
        ItemIndex = 1
        Items.Strings = (
          'Local System Voice'
          'OpenAI Voice API'
        )
        Style = csDropDownList
        TabOrder = 0
        Text = 'OpenAI Voice API'
      end
      object lblToken: TLabel
        Left = 20
        Height = 15
        Top = 60
        Width = 53
        Caption = 'API token:'
        ParentColor = False
      end
      object edtOpenAIToken: TEdit
        Left = 150
        Height = 23
        Top = 56
        Width = 300
        EchoMode = emPassword
        PasswordChar = '*'
        TabOrder = 1
      end
      object lblModel: TLabel
        Left = 20
        Height = 15
        Top = 100
        Width = 78
        Caption = 'OpenAI model:'
        ParentColor = False
      end
      object cbOpenAIModel: TComboBox
        Left = 150
        Height = 23
        Top = 96
        Width = 300
        ItemHeight = 15
        ItemIndex = 0
        Items.Strings = (
          'gpt-4o-mini-tts'
          'tts-1'
          'tts-1-hd'
        )
        Style = csDropDownList
        TabOrder = 2
        Text = 'gpt-4o-mini-tts'
      end
      object lblVoice: TLabel
        Left = 20
        Height = 15
        Top = 140
        Width = 74
        Caption = 'OpenAI voice:'
        ParentColor = False
      end
      object cbOpenAIVoice: TComboBox
        Left = 150
        Height = 23
        Top = 136
        Width = 300
        ItemHeight = 15
        ItemIndex = 0
        Items.Strings = (
          'alloy'
          'ash'
          'ballad'
          'coral'
          'echo'
          'fable'
          'nova'
          'onyx'
          'sage'
          'shimmer'
          'verse'
          'marin'
          'cedar'
        )
        Style = csDropDownList
        TabOrder = 3
        Text = 'alloy'
      end
      object lblLanguage: TLabel
        Left = 20
        Height = 15
        Top = 180
        Width = 55
        Caption = 'Language:'
        ParentColor = False
      end
      object cbLanguage: TComboBox
        Left = 150
        Height = 23
        Top = 176
        Width = 300
        ItemHeight = 15
        ItemIndex = 0
        Items.Strings = (
          'en-US - English (United States)'
          'en-GB - English (United Kingdom)'
          'pt-BR - Portuguese (Brazil)'
          'es-ES - Spanish (Spain)'
          'fr-FR - French (France)'
          'it-IT - Italian (Italy)'
          'de-DE - German (Germany)'
          'ja-JP - Japanese (Japan)'
          'zh-CN - Chinese (Simplified)'
        )
        Style = csDropDownList
        TabOrder = 4
        Text = 'en-US - English (United States)'
      end
      object lblFormat: TLabel
        Left = 20
        Height = 15
        Top = 220
        Width = 80
        Caption = 'Output format:'
        ParentColor = False
      end
      object cbOutputFormat: TComboBox
        Left = 150
        Height = 23
        Top = 216
        Width = 300
        ItemHeight = 15
        ItemIndex = 0
        Items.Strings = (
          'mp3'
          'wav'
          'opus'
          'aac'
          'flac'
          'pcm'
        )
        Style = csDropDownList
        TabOrder = 5
        Text = 'mp3'
      end
      object lblSpeed: TLabel
        Left = 20
        Height = 15
        Top = 260
        Width = 35
        Caption = 'Speed:'
        ParentColor = False
      end
      object edtSpeed: TEdit
        Left = 150
        Height = 23
        Top = 256
        Width = 300
        TabOrder = 6
        Text = '1.0'
      end
      object lblOutputFile: TLabel
        Left = 20
        Height = 15
        Top = 300
        Width = 60
        Caption = 'Output file:'
        ParentColor = False
      end
      object edtOutputFile: TEdit
        Left = 150
        Height = 23
        Top = 296
        Width = 400
        TabOrder = 7
        Text = 'speech.mp3'
      end
      object btnSelectOutputFile: TButton
        Left = 560
        Height = 25
        Top = 295
        Width = 150
        Caption = 'Select Output File'
        OnClick = btnSelectOutputFileClick
        TabOrder = 8
      end
      object btnApplyConfig: TButton
        Left = 150
        Height = 35
        Top = 350
        Width = 150
        Caption = 'Apply Configuration'
        OnClick = btnApplyConfigClick
        TabOrder = 9
      end
      object btnTestConfig: TButton
        Left = 310
        Height = 35
        Top = 350
        Width = 150
        Caption = 'Test Configuration'
        OnClick = btnTestConfigClick
        TabOrder = 10
      end
    end
    object tsSpeech: TTabSheet
      Caption = 'Speech'
      ClientHeight = 552
      ClientWidth = 772
      TabOrder = 1
      object lblSpeechText: TLabel
        Left = 15
        Height = 15
        Top = 15
        Width = 103
        Caption = 'Text to synthesize:'
        ParentColor = False
      end
      object memoSpeechText: TMemo
        Left = 15
        Height = 280
        Top = 40
        Width = 740
        ScrollBars = ssAutoBoth
        TabOrder = 0
      end
      object btnSpeak: TButton
        Left = 15
        Height = 35
        Top = 340
        Width = 180
        Caption = 'Generate Speech'
        OnClick = btnSpeakClick
        TabOrder = 1
      end
      object btnClearText: TButton
        Left = 210
        Height = 35
        Top = 340
        Width = 120
        Caption = 'Clear Text'
        OnClick = btnClearTextClick
        TabOrder = 2
      end
      object btnLoadExample: TButton
        Left = 340
        Height = 35
        Top = 340
        Width = 120
        Caption = 'Load Example'
        OnClick = btnLoadExampleClick
        TabOrder = 3
      end
    end
    object tsOutput: TTabSheet
      Caption = 'Output'
      ClientHeight = 552
      ClientWidth = 772
      TabOrder = 2
      object lblGeneratedFile: TLabel
        Left = 15
        Height = 15
        Top = 15
        Width = 111
        Caption = 'Generated audio file:'
        ParentColor = False
      end
      object edtGeneratedFile: TEdit
        Left = 15
        Height = 23
        Top = 40
        Width = 550
        ReadOnly = True
        TabOrder = 0
      end
      object btnPlayAudio: TButton
        Left = 15
        Height = 30
        Top = 80
        Width = 120
        Caption = 'Play Audio'
        OnClick = btnPlayAudioClick
        TabOrder = 1
      end
      object btnOpenOutputFolder: TButton
        Left = 145
        Height = 30
        Top = 80
        Width = 150
        Caption = 'Open Output Folder'
        OnClick = btnOpenOutputFolderClick
        TabOrder = 2
      end
      object btnCopyPath: TButton
        Left = 305
        Height = 30
        Top = 80
        Width = 120
        Caption = 'Copy Path'
        OnClick = btnCopyPathClick
        TabOrder = 3
      end
      object lblLastResult: TLabel
        Left = 15
        Height = 15
        Top = 130
        Width = 58
        Caption = 'Last result:'
        ParentColor = False
      end
      object memoLastResult: TMemo
        Left = 15
        Height = 200
        Top = 155
        Width = 740
        ReadOnly = True
        ScrollBars = ssAutoBoth
        TabOrder = 4
      end
    end
    object tsLog: TTabSheet
      Caption = 'Log'
      ClientHeight = 552
      ClientWidth = 772
      TabOrder = 3
      object memoLog: TMemo
        Left = 0
        Height = 502
        Top = 0
        Width = 772
        Align = alClient
        ScrollBars = ssAutoBoth
        TabOrder = 0
      end
      object pnlLogButtons: TPanel
        Left = 0
        Height = 50
        Top = 502
        Width = 772
        Align = alBottom
        ClientHeight = 50
        ClientWidth = 772
        TabOrder = 1
        object btnClearLog: TButton
          Left = 15
          Height = 30
          Top = 10
          Width = 120
          Caption = 'Clear Log'
          OnClick = btnClearLogClick
          TabOrder = 0
        end
      end
    end
  end
  object dlgSaveAudio: TSaveDialog
    Title = 'Select Output File'
    DefaultExt = '.mp3'
    Filter = 'Audio Files (*.mp3, *.wav, *.opus, *.aac, *.flac, *.pcm)|*.mp3;*.wav;*.opus;*.aac;*.flac;*.pcm|All Files (*.*)|*.*'
    Left = 600
    Top = 380
  end
end
