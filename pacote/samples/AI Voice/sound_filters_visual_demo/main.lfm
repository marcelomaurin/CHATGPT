object frmMain: TfrmMain
  Left = 320
  Height = 680
  Top = 120
  Width = 840
  Caption = 'Sound Filters Visual Demo - Real Signal Processing'
  ClientHeight = 680
  ClientWidth = 840
  LCLVersion = '4.4.0.0'
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  object pnlTop: TPanel
    Left = 0
    Height = 80
    Top = 0
    Width = 840
    Align = alTop
    BevelOuter = bvNone
    ClientHeight = 80
    ClientWidth = 840
    Color = clForm
    ParentBackground = False
    ParentColor = False
    TabOrder = 0
    object lblTitle: TLabel
      Left = 15
      Height = 28
      Top = 15
      Width = 248
      Caption = 'Sound Filters Visual Demo'
      Font.CharSet = ANSI_CHARSET
      Font.Height = -20
      Font.Name = 'Segoe UI'
      Font.Pitch = fpVariable
      Font.Quality = fqDraft
      Font.Style = [fsBold]
      ParentColor = False
      ParentFont = False
    end
    object lblSubtitle: TLabel
      Left = 15
      Height = 15
      Top = 45
      Width = 476
      Caption = 'Process generated audio signals using real low-pass, high-pass and moving average filters.'
      Font.CharSet = ANSI_CHARSET
      Font.Height = -12
      Font.Name = 'Segoe UI'
      Font.Pitch = fpVariable
      Font.Quality = fqDraft
      ParentColor = False
      ParentFont = False
    end
  end
  object pnlStatus: TPanel
    Left = 0
    Height = 35
    Top = 645
    Width = 840
    Align = alBottom
    Alignment = taLeftJustify
    BevelOuter = bvNone
    ClientHeight = 35
    ClientWidth = 840
    TabOrder = 1
    object lblStatus: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 75
      Caption = 'Status: Ready'
      Font.CharSet = ANSI_CHARSET
      Font.Height = -12
      Font.Name = 'Segoe UI'
      Font.Pitch = fpVariable
      Font.Quality = fqDraft
      Font.Style = [fsBold]
      ParentColor = False
      ParentFont = False
    end
  end
  object pcMain: TPageControl
    Left = 0
    Height = 565
    Top = 80
    Width = 840
    ActivePage = tsSignal
    Align = alClient
    TabIndex = 0
    TabOrder = 2
    object tsSignal: TTabSheet
      Caption = 'Signal'
      ClientHeight = 537
      ClientWidth = 832
      object lblSampleRate: TLabel
        Left = 20
        Height = 15
        Top = 20
        Width = 90
        Caption = 'Sample rate (Hz):'
        ParentColor = False
      end
      object edtSampleRate: TEdit
        Left = 20
        Height = 23
        Top = 40
        Width = 150
        TabOrder = 0
        Text = '44100'
      end
      object lblDuration: TLabel
        Left = 20
        Height = 15
        Top = 80
        Width = 103
        Caption = 'Duration (seconds):'
        ParentColor = False
      end
      object edtDuration: TEdit
        Left = 20
        Height = 23
        Top = 100
        Width = 150
        TabOrder = 1
        Text = '1.0'
      end
      object lblBaseFrequency: TLabel
        Left = 20
        Height = 15
        Top = 140
        Width = 108
        Caption = 'Base frequency (Hz):'
        ParentColor = False
      end
      object edtBaseFrequency: TEdit
        Left = 20
        Height = 23
        Top = 160
        Width = 150
        TabOrder = 2
        Text = '1000'
      end
      object lblNoiseFrequency: TLabel
        Left = 20
        Height = 15
        Top = 200
        Width = 114
        Caption = 'Noise frequency (Hz):'
        ParentColor = False
      end
      object edtNoiseFrequency: TEdit
        Left = 20
        Height = 23
        Top = 220
        Width = 150
        TabOrder = 3
        Text = '12000'
      end
      object lblNoiseAmplitude: TLabel
        Left = 20
        Height = 15
        Top = 260
        Width = 90
        Caption = 'Noise amplitude:'
        ParentColor = False
      end
      object edtNoiseAmplitude: TEdit
        Left = 20
        Height = 23
        Top = 280
        Width = 150
        TabOrder = 4
        Text = '0.35'
      end
      object btnGenerateSignal: TButton
        Left = 20
        Height = 35
        Top = 330
        Width = 150
        Caption = 'Generate Signal'
        TabOrder = 5
        OnClick = btnGenerateSignalClick
      end
      object btnClearSignal: TButton
        Left = 190
        Height = 35
        Top = 330
        Width = 150
        Caption = 'Clear Signal'
        TabOrder = 6
        OnClick = btnClearSignalClick
