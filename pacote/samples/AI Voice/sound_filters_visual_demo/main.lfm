object frmMain: TfrmMain
  Left = 320
  Height = 650
  Top = 150
  Width = 780
  Caption = 'Sound Filters Visual Demo - Real Signal Processing'
  ClientHeight = 650
  ClientWidth = 780
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  LCLVersion = '2.2.6.0'
  object pnlTop: TPanel
    Left = 0
    Height = 80
    Top = 0
    Width = 780
    Align = alTop
    BevelOuter = bvNone
    Color = clForm
    TabOrder = 0
    object lblTitle: TLabel
      Left = 15
      Height = 25
      Top = 15
      Width = 350
      Caption = 'Sound Filters Visual Demo'
      Font.CharSet = ANSI_CHARSET
      Font.Height = -20
      Font.Name = 'Segoe UI'
      Font.Pitch = fpVariable
      Font.Quality = fqDraft
      Font.Style = [fsBold]
      ParentColor = False
      ParentFont = False
    end
    object lblSubtitle: TLabel
      Left = 15
      Height = 15
      Top = 45
      Width = 530
      Caption = 'Process generated audio signals using real low-pass, high-pass and moving average filters.'
      Font.CharSet = ANSI_CHARSET
      Font.Height = -12
      Font.Name = 'Segoe UI'
      Font.Pitch = fpVariable
      Font.Quality = fqDraft
      ParentColor = False
      ParentFont = False
    end
  end
  object pnlStatus: TPanel
    Left = 0
    Height = 35
    Top = 615
    Width = 780
    Align = alBottom
    Alignment = taLeftJustify
    BevelOuter = bvNone
    ClientHeight = 35
    ClientWidth = 780
    TabOrder = 1
    object lblStatus: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 75
      Caption = 'Status: Ready'
      Font.CharSet = ANSI_CHARSET
      Font.Height = -12
      Font.Name = 'Segoe UI'
      Font.Pitch = fpVariable
      Font.Quality = fqDraft
      Font.Style = [fsBold]
      ParentColor = False
      ParentFont = False
    end
  end
  object pcMain: TPageControl
    Left = 0
    Height = 535
    Top = 80
    Width = 780
    ActivePage = tsSignal
    Align = alClient
    TabIndex = 0
    TabOrder = 2
    object tsSignal: TTabSheet
      Caption = 'Signal'
      ClientHeight = 507
      ClientWidth = 772
      object lblSampleRate: TLabel
        Left = 20
        Height = 15
        Top = 20
        Width = 90
        Caption = 'Sample rate (Hz):'
        ParentColor = False
      end
      object edtSampleRate: TEdit
        Left = 20
        Height = 23
        Top = 40
        Width = 150
        TabOrder = 0
        Text = '44100'
      end
      object lblDuration: TLabel
        Left = 20
        Height = 15
        Top = 80
        Width = 102
        Caption = 'Duration (seconds):'
        ParentColor = False
      end
      object edtDuration: TEdit
        Left = 20
        Height = 23
        Top = 100
        Width = 150
        TabOrder = 1
        Text = '1.0'
      end
      object lblBaseFrequency: TLabel
        Left = 20
        Height = 15
        Top = 140
        Width = 113
        Caption = 'Base frequency (Hz):'
        ParentColor = False
      end
      object edtBaseFrequency: TEdit
        Left = 20
        Height = 23
        Top = 160
        Width = 150
        TabOrder = 2
        Text = '1000'
      end
      object lblNoiseFrequency: TLabel
        Left = 20
        Height = 15
        Top = 200
        Width = 119
        Caption = 'Noise frequency (Hz):'
        ParentColor = False
      end
      object edtNoiseFrequency: TEdit
        Left = 20
        Height = 23
        Top = 220
        Width = 150
        TabOrder = 3
        Text = '12000'
      end
      object lblNoiseAmplitude: TLabel
        Left = 20
        Height = 15
        Top = 260
        Width = 91
        Caption = 'Noise amplitude:'
        ParentColor = False
      end
      object edtNoiseAmplitude: TEdit
        Left = 20
        Height = 23
        Top = 280
        Width = 150
        TabOrder = 4
        Text = '0.35'
      end
      object btnGenerateSignal: TButton
        Left = 20
        Height = 35
        Top = 330
        Width = 150
        Caption = 'Generate Signal'
        OnClick = btnGenerateSignalClick
        TabOrder = 5
      end
      object btnClearSignal: TButton
        Left = 190
        Height = 35
        Top = 330
        Width = 150
        Caption = 'Clear Signal'
        OnClick = btnClearSignalClick
        TabOrder = 6
      end
    end
    object tsFilters: TTabSheet
      Caption = 'Filters'
      ClientHeight = 507
      ClientWidth = 772
      object lblFilterType: TLabel
        Left = 20
        Height = 15
        Top = 20
        Width = 57
        Caption = 'Filter type:'
        ParentColor = False
      end
      object cbFilterType: TComboBox
        Left = 20
        Height = 23
        Top = 40
        Width = 200
        ItemHeight = 15
        ItemIndex = 0
        Items.Strings = (
          'Low-pass'
          'High-pass'
          'Moving average'
        )
        Style = csDropDownList
        TabOrder = 0
        Text = 'Low-pass'
      end
      object lblLowPassCutoff: TLabel
        Left = 20
        Height = 15
        Top = 80
        Width = 197
        Caption = 'Low-pass cutoff frequency (Hz):'
        ParentColor = False
      end
      object edtLowPassCutoff: TEdit
        Left = 20
        Height = 23
        Top = 100
        Width = 200
        TabOrder = 1
        Text = '4000'
      end
      object lblHighPassCutoff: TLabel
        Left = 20
        Height = 15
        Top = 140
        Width = 202
        Caption = 'High-pass cutoff frequency (Hz):'
        ParentColor = False
      end
      object edtHighPassCutoff: TEdit
        Left = 20
        Height = 23
        Top = 160
        Width = 200
        TabOrder = 2
        Text = '12000'
      end
      object lblAverageWindow: TLabel
        Left = 20
        Height = 15
        Top = 200
        Width = 153
        Caption = 'Moving average window size:'
        ParentColor = False
      end
      object edtAverageWindow: TEdit
        Left = 20
        Height = 23
        Top = 220
        Width = 200
        TabOrder = 3
        Text = '5'
      end
      object btnApplyFilter: TButton
        Left = 20
        Height = 35
        Top = 270
        Width = 150
        Caption = 'Apply Filter'
        OnClick = btnApplyFilterClick
        TabOrder = 4
      end
      object btnResetFilters: TButton
        Left = 190
        Height = 35
        Top = 270
        Width = 150
        Caption = 'Reset Filters'
        OnClick = btnResetFiltersClick
        TabOrder = 5
      end
    end
    object tsResult: TTabSheet
      Caption = 'Result'
      ClientHeight = 507
      ClientWidth = 772
      object lblInputSignal: TLabel
        Left = 20
        Height = 15
        Top = 10
        Width = 63
        Caption = 'Input signal'
        Font.Style = [fsBold]
        ParentColor = False
        ParentFont = False
      end
      object pbInputSignal: TPaintBox
        Left = 20
        Height = 150
        Top = 30
        Width = 450
        OnPaint = pbInputSignalPaint
      end
      object lblFilteredSignal: TLabel
        Left = 20
        Height = 15
        Top = 195
        Width = 78
        Caption = 'Filtered signal'
        Font.Style = [fsBold]
        ParentColor = False
        ParentFont = False
      end
      object pbOutputSignal: TPaintBox
        Left = 20
        Height = 150
        Top = 215
        Width = 450
        OnPaint = pbOutputSignalPaint
      end
      object lblMetrics: TLabel
        Left = 490
        Height = 15
        Top = 10
        Width = 86
        Caption = 'Signal Metrics:'
        Font.Style = [fsBold]
        ParentColor = False
        ParentFont = False
      end
      object memoMetrics: TMemo
        Left = 490
        Height = 335
        Top = 30
        Width = 260
        ReadOnly = True
        ScrollBars = ssAutoVertical
        TabOrder = 0
      end
      object btnExportCSV: TButton
        Left = 20
        Height = 35
        Top = 385
        Width = 150
        Caption = 'Export CSV'
        OnClick = btnExportCSVClick
        TabOrder = 1
      end
      object btnCopyMetrics: TButton
        Left = 190
        Height = 35
        Top = 385
        Width = 150
        Caption = 'Copy Metrics'
        OnClick = btnCopyMetricsClick
        TabOrder = 2
      end
    end
    object tsLog: TTabSheet
      Caption = 'Log'
      ClientHeight = 507
      ClientWidth = 772
      object memoLog: TMemo
        Left = 20
        Height = 380
        Top = 20
        Width = 730
        ReadOnly = True
        ScrollBars = ssAutoBoth
        TabOrder = 0
      end
      object btnClearLog: TButton
        Left = 20
        Height = 35
        Top = 415
        Width = 150
        Caption = 'Clear Log'
        OnClick = btnClearLogClick
        TabOrder = 1
      end
    end
  end
  object dlgSave: TSaveDialog
    Title = 'Export Signal to CSV'
    DefaultExt = '.csv'
    Filter = 'CSV Files (*.csv)|*.csv|All Files (*.*)|*.*'
    Left = 720
    Top = 10
  end
end
