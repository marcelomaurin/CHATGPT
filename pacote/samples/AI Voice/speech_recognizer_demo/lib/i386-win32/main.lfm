object frmMain: TfrmMain
  Left = 300
  Height = 650
  Top = 150
  Width = 840
  Caption = 'Audio Capture Demo - Real Microphone Recording'
  ClientHeight = 650
  ClientWidth = 840
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  LCLVersion = '3.0.0.3'
  object pnlTop: TPanel
    Left = 0
    Height = 80
    Top = 0
    Width = 840
    Align = alTop
    BevelOuter = bvNone
    ClientHeight = 80
    ClientWidth = 840
    TabOrder = 0
    object lblTitle: TLabel
      Left = 15
      Height = 25
      Top = 15
      Width = 190
      Caption = 'Audio Capture Demo'
      Font.Height = -18
      Font.Name = 'Segoe UI'
      Font.Style = [fsBold]
      ParentColor = False
    end
    object lblSubtitle: TLabel
      Left = 15
      Height = 15
      Top = 45
      Width = 469
      Caption = 'Capture real audio from the system microphone and save it as a WAV file.'
      ParentColor = False
    end
  end
  object pnlStatus: TPanel
    Left = 0
    Height = 35
    Top = 615
    Width = 840
    Align = alBottom
    Alignment = taLeftJustify
    BevelOuter = bvNone
    ClientHeight = 35
    ClientWidth = 840
    TabOrder = 1
    object lblStatus: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 75
      Caption = 'Status: Ready'
      Font.Style = [fsBold]
      ParentColor = False
    end
  end
  object pcMain: TPageControl
    Left = 0
    Height = 500
    Top = 80
    Width = 840
    ActivePage = tsConfiguration
    Align = alClient
    TabIndex = 0
    TabOrder = 2
    object tsConfiguration: TTabSheet
      Caption = 'Configuration'
      object lblInputSource: TLabel
        Left = 20
        Height = 15
        Top = 20
        Width = 71
        Caption = 'Input source:'
        ParentColor = False
      end
      object cbInputSource: TComboBox
        Left = 20
        Height = 23
        Top = 40
        Width = 200
        ItemHeight = 15
        ItemIndex = 0
        Items.Strings = (
          'Microphone'
        )
        Style = csDropDownList
        TabOrder = 0
        Text = 'Microphone'
      end
      object lblSampleRate: TLabel
        Left = 20
        Height = 15
        Top = 80
        Width = 67
        Caption = 'Sample rate:'
        ParentColor = False
      end
      object cbSampleRate: TComboBox
        Left = 20
        Height = 23
        Top = 100
        Width = 200
        ItemHeight = 15
        ItemIndex = 1
        Items.Strings = (
          '8000'
          '16000'
          '22050'
          '44100'
          '48000'
        )
        Style = csDropDownList
        TabOrder = 1
        Text = '16000'
      end
      object lblChannels: TLabel
        Left = 20
        Height = 15
        Top = 140
        Width = 52
        Caption = 'Channels:'
        ParentColor = False
      end
      object cbChannels: TComboBox
        Left = 20
        Height = 23
        Top = 160
        Width = 200
        ItemHeight = 15
        ItemIndex = 0
        Items.Strings = (
          '1 - Mono'
          '2 - Stereo'
        )
        Style = csDropDownList
        TabOrder = 2
        Text = '1 - Mono'
      end
      object lblDurationLimit: TLabel
        Left = 20
        Height = 15
        Top = 200
        Width = 127
        Caption = 'Duration limit (seconds):'
        ParentColor = False
      end
      object edtDurationLimit: TEdit
        Left = 20
        Height = 23
        Top = 220
        Width = 200
        TabOrder = 3
        Text = '5'
      end
      object lblOutputFile: TLabel
        Left = 250
        Height = 15
        Top = 20
        Width = 98
        Caption = 'Output WAV file:'
        ParentColor = False
      end
      object edtOutputFile: TEdit
        Left = 250
        Height = 23
        Top = 40
        Width = 350
        TabOrder = 4
        Text = 'output/voice_rec.wav'
      end
      object btnSelectOutputFile: TButton
        Left = 610
        Height = 25
        Top = 39
        Width = 130
        Caption = 'Select Output File'
        OnClick = btnSelectOutputFileClick
        TabOrder = 5
      end
      object btnApplyConfig: TButton
        Left = 250
        Height = 35
        Top = 95
        Width = 160
        Caption = 'Apply Configuration'
        OnClick = btnApplyConfigClick
        TabOrder = 6
      end
      object btnTestBackend: TButton
        Left = 430
        Height = 35
        Top = 95
        Width = 160
        Caption = 'Test Audio Backend'
        OnClick = btnTestBackendClick
        TabOrder = 7
      end
    end
    object tsRecording: TTabSheet
      Caption = 'Recording'
      object btnStartRecording: TButton
        Left = 20
        Height = 40
        Top = 20
        Width = 150
        Caption = 'Start Recording'
        OnClick = btnStartRecordingClick
        TabOrder = 0
      end
      object btnStopRecording: TButton
        Left = 190
        Height = 40
        Top = 20
        Width = 150
        Caption = 'Stop Recording'
        Enabled = False
        OnClick = btnStopRecordingClick
        TabOrder = 1
      end
      object btnPlayRecording: TButton
        Left = 360
        Height = 40
        Top = 20
        Width = 150
        Caption = 'Play Recording'
        Enabled = False
        OnClick = btnPlayRecordingClick
        TabOrder = 2
      end
      object lblRecordingState: TLabel
        Left = 20
        Height = 15
        Top = 85
        Width = 145
        Caption = 'Recording state: stopped'
        Font.Style = [fsBold]
        ParentColor = False
      end
      object lblElapsedTime: TLabel
        Left = 20
        Height = 15
        Top = 115
        Width = 107
        Caption = 'Elapsed time: 00:00'
        ParentColor = False
      end
      object pbRecordingTime: TProgressBar
        Left = 20
        Height = 20
        Top = 145
        Width = 490
        TabOrder = 3
      end
      object memoRecordingInfo: TMemo
        Left = 20
        Height = 150
        Top = 185
        Width = 490
        ReadOnly = True
        ScrollBars = ssAutoVertical
        TabOrder = 4
      end
    end
    object tsResult: TTabSheet
      Caption = 'Result'
      object lblGeneratedFile: TLabel
        Left = 20
        Height = 15
        Top = 20
        Width = 81
        Caption = 'Generated file:'
        ParentColor = False
      end
      object edtGeneratedFile: TEdit
        Left = 20
        Height = 23
        Top = 40
        Width = 480
        ReadOnly = True
        TabOrder = 0
      end
      object lblValidationResultLabel: TLabel
        Left = 20
        Height = 15
        Top = 80
        Width = 98
        Caption = 'Validation result:'
        ParentColor = False
      end
      object lblValidationResult: TLabel
        Left = 20
        Height = 20
        Top = 100
        Width = 480
        Caption = 'N/A'
        Font.Height = -13
        Font.Style = [fsBold]
        ParentColor = False
      end
      object memoResult: TMemo
        Left = 20
        Height = 200
        Top = 140
        Width = 480
        ReadOnly = True
        ScrollBars = ssAutoVertical
        TabOrder = 1
      end
    end
    object tsLog: TTabSheet
      Caption = 'Log'
      object memoLog: TMemo
        Left = 20
        Height = 350
        Top = 20
        Width = 780
        ReadOnly = True
        ScrollBars = ssAutoBoth
        TabOrder = 0
      end
      object btnClearLog: TButton
        Left = 20
        Height = 35
        Top = 385
        Width = 120
        Caption = 'Clear Log'
        OnClick = btnClearLogClick
        TabOrder = 1
      end
    end
  end
  object SaveDialog1: TSaveDialog
    Title = 'Select Output WAV File'
    DefaultExt = '.wav'
    Filter = 'WAV Audio (*.wav)|*.wav|All files (*.*)|*.*'
    Left = 700
    Top = 10
  end
  object TimerRecording: TTimer
    Enabled = False
    Interval = 500
    OnTimer = TimerRecordingTimer
    Left = 750
    Top = 10
  end
end
