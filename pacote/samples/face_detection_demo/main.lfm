object frmFaceDemo: TfrmFaceDemo
  Left = 320
  Height = 650
  Top = 150
  Width = 900
  Caption = 'TFaceDetection Showcase - Detecção Facial OpenCV'
  ClientHeight = 650
  ClientWidth = 900
  LCLVersion = '4.4.0.0'
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  object pnlConfig: TPanel
    Left = 10
    Height = 115
    Top = 10
    Width = 880
    Align = alTop
    BorderSpacing.Around = 10
    ClientHeight = 115
    ClientWidth = 880
    TabOrder = 0
    object lblDLLPath: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 280
      Caption = 'Escolha a DLL do Python:'
      ParentColor = False
    end
    object lbDLLs: TListBox
      Left = 15
      Height = 70
      Top = 30
      Width = 280
      ItemHeight = 0
      TabOrder = 0
    end
    object btnToggleActive: TButton
      Left = 310
      Height = 35
      Top = 35
      Width = 140
      Caption = 'Ativar Python'
      TabOrder = 1
      OnClick = btnToggleActiveClick
    end
    object btnInstallDeps: TButton
      Left = 460
      Height = 35
      Top = 35
      Width = 180
      Caption = 'Instalar OpenCV (Pip)'
      TabOrder = 2
      OnClick = btnInstallDepsClick
    end
    object lblStatus: TLabel
      Left = 660
      Height = 15
      Top = 45
      Width = 131
      Caption = 'Status: Python INATIVO'
      Font.Color = clRed
      Font.Style = [fsBold]
      ParentColor = False
      ParentFont = False
    end
  end
  object pnlImage: TPanel
    Left = 10
    Height = 90
    Top = 100
    Width = 880
    Align = alTop
    BorderSpacing.Around = 10
    ClientHeight = 90
    ClientWidth = 880
    TabOrder = 1
    object lblImage: TLabel
      Left = 15
      Height = 15
      Top = 15
      Width = 108
      Caption = 'Arquivo de Imagem:'
      ParentColor = False
    end
    object edImagePath: TEdit
      Left = 15
      Height = 23
      Top = 35
      Width = 530
      TabOrder = 0
    end
    object btnSelectImg: TButton
      Left = 560
      Height = 25
      Top = 33
      Width = 140
      Caption = 'Procurar Imagem...'
      TabOrder = 1
      OnClick = btnSelectImgClick
    end
    object btnDetect: TButton
      Left = 715
      Height = 45
      Top = 20
      Width = 145
      Caption = 'Detectar Faces'
      Font.Style = [fsBold]
      ParentFont = False
      TabOrder = 2
      OnClick = btnDetectClick
    end
  end
  object imgView: TImage
    Left = 10
    Height = 440
    Top = 200
    Width = 550
    Align = alLeft
    BorderSpacing.Left = 10
    BorderSpacing.Bottom = 10
    Center = True
    Proportional = True
    Stretch = True
  end
  object meLogs: TMemo
    Left = 560
    Height = 440
    Top = 200
    Width = 330
    Align = alClient
    BorderSpacing.Right = 10
    BorderSpacing.Bottom = 10
    ReadOnly = True
    ScrollBars = ssAutoBoth
    TabOrder = 2
  end
  object lblLogs: TLabel
    Left = 575
    Height = 15
    Top = 182
    Width = 103
    Caption = 'Logs de Operações:'
    ParentColor = False
  end
end
