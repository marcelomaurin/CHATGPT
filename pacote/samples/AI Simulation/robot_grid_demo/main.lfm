object frmMain: TfrmMain
  Left = 350
  Height = 620
  Top = 150
  Width = 850
  Caption = 'Lazarus AI Suite - Robot Grid Simulation'
  ClientHeight = 620
  ClientWidth = 850
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  Position = poScreenCenter
  object pbGrid: TPaintBox
    Left = 0
    Height = 620
    Top = 0
    Width = 580
    Align = alClient
    OnPaint = pbGridPaint
  end
  object pnlControl: TPanel
    Left = 580
    Height = 620
    Top = 0
    Width = 270
    Align = alRight
    ClientHeight = 620
    ClientWidth = 270
    TabOrder = 0
    object btnStart: TButton
      Left = 16
      Height = 30
      Top = 10
      Width = 238
      Caption = 'Iniciar Simulação'
      OnClick = btnStartClick
      TabOrder = 0
    end
    object btnPause: TButton
      Left = 16
      Height = 30
      Top = 45
      Width = 238
      Caption = 'Pausar'
      OnClick = btnPauseClick
      TabOrder = 1
    end
    object btnStep: TButton
      Left = 16
      Height = 30
      Top = 80
      Width = 238
      Caption = 'Passo a Passo (Step)'
      OnClick = btnStepClick
      TabOrder = 2
    end
    object btnStop: TButton
      Left = 16
      Height = 30
      Top = 115
      Width = 238
      Caption = 'Parar'
      OnClick = btnStopClick
      TabOrder = 3
    end
    object btnReset: TButton
      Left = 16
      Height = 30
      Top = 150
      Width = 238
      Caption = 'Reiniciar Cenário'
      OnClick = btnResetClick
      TabOrder = 4
    end
    object lblStatsTitle: TLabel
      Left = 16
      Height = 15
      Top = 195
      Width = 238
      Caption = 'Estatísticas de Simulação:'
      Font.Style = [fsBold]
      ParentColor = False
    end
    object lblCycles: TLabel
      Left = 16
      Height = 15
      Top = 215
      Width = 238
      Caption = 'Ciclos: 0'
      ParentColor = False
    end
    object lblActive: TLabel
      Left = 16
      Height = 15
      Top = 235
      Width = 238
      Caption = 'Robôs Ativos: 0'
      ParentColor = False
    end
    object lblMoving: TLabel
      Left = 16
      Height = 15
      Top = 255
      Width = 238
      Caption = 'Em Movimento: 0'
      ParentColor = False
    end
    object lblSeekingCharge: TLabel
      Left = 16
      Height = 15
      Top = 275
      Width = 238
      Caption = 'Buscando Recarga: 0'
      ParentColor = False
    end
    object lblCharging: TLabel
      Left = 16
      Height = 15
      Top = 295
      Width = 238
      Caption = 'Carregando: 0'
      ParentColor = False
    end
    object lblBlocked: TLabel
      Left = 16
      Height = 15
      Top = 315
      Width = 238
      Caption = 'Bloqueados: 0'
      ParentColor = False
    end
    object lblInactive: TLabel
      Left = 16
      Height = 15
      Top = 335
      Width = 238
      Caption = 'Inativos: 0'
      ParentColor = False
    end
    object lblDead: TLabel
      Left = 16
      Height = 15
      Top = 355
      Width = 238
      Caption = 'Sem Energia: 0'
      ParentColor = False
    end
    object lblRecharges: TLabel
      Left = 16
      Height = 15
      Top = 375
      Width = 238
      Caption = 'Recargas Realizadas: 0'
      ParentColor = False
    end
    object lblCycleMoves: TLabel
      Left = 16
      Height = 15
      Top = 395
      Width = 238
      Caption = 'Movimentos no Ciclo: 0'
      ParentColor = False
    end
    object lblTotalMoves: TLabel
      Left = 16
      Height = 15
      Top = 415
      Width = 238
      Caption = 'Movimentos Totais: 0'
      ParentColor = False
    end
    object lblLogTitle: TLabel
      Left = 16
      Height = 15
      Top = 445
      Width = 238
      Caption = 'Últimos Eventos:'
      Font.Style = [fsBold]
      ParentColor = False
    end
    object lblLastEvent: TLabel
      Left = 16
      Height = 15
      Top = 465
      Width = 238
      Caption = 'Último Evento: N/A'
      ParentColor = False
    end
    object lblStatus: TLabel
      Left = 16
      Height = 15
      Top = 495
      Width = 238
      Caption = 'Status: Parado'
      ParentColor = False
    end
  end
end
