object frmMain: TfrmMain
  Left = 350
  Height = 620
  Top = 150
  Width = 850
  Caption = 'Lazarus AI Suite - Warehouse Logistics Simulation'
  ClientHeight = 620
  ClientWidth = 850
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  Position = poScreenCenter
  object pbGrid: TPaintBox
    Left = 0
    Height = 620
    Top = 0
    Width = 580
    Align = alClient
    OnPaint = pbGridPaint
  end
  object pnlControl: TPanel
    Left = 580
    Height = 620
    Top = 0
    Width = 270
    Align = alRight
    ClientHeight = 620
    ClientWidth = 270
    TabOrder = 0
    object btnStart: TButton
      Left = 16
      Height = 30
      Top = 10
      Width = 238
      Caption = 'Iniciar Simulação'
      OnClick = btnStartClick
      TabOrder = 0
    end
    object btnPause: TButton
      Left = 16
      Height = 30
      Top = 45
      Width = 238
      Caption = 'Pausar'
      OnClick = btnPauseClick
      TabOrder = 1
    end
    object btnStep: TButton
      Left = 16
      Height = 30
      Top = 80
      Width = 238
