object frmMain: TfrmMain
  Left = 320
  Height = 600
  Top = 150
  Width = 800
  Caption = 'Data Dictionary Generator - AI DBase'
  ClientHeight = 600
  ClientWidth = 800
  OnCreate = FormCreate
  Position = poScreenCenter
  LCLVersion = '2.2.0.4'
  object pnlConfig: TPanel
    Left = 0
    Height = 180
    Top = 0
    Width = 800
    Align = alTop
    ClientHeight = 180
    ClientWidth = 800
    TabOrder = 0
    object lblBanco: TLabel
      Left = 16
      Height = 15
      Top = 16
      Width = 36
      Caption = 'Database:'
      ParentColor = False
    end
    object cbBanco: TComboBox
      Left = 70
      Height = 23
      Top = 12
      Width = 150
      ItemHeight = 15
      ItemIndex = 0
      Items.Strings = (
        'PostgreSQL'
        'SQLite'
      )
      Style = csDropDownList
      TabOrder = 0
      Text = 'PostgreSQL'
      OnChange = cbBancoChange
    end
    object lblHost: TLabel
      Left = 16
      Height = 15
      Top = 48
      Width = 28
      Caption = 'Host:'
      ParentColor = False
    end
    object edtHost: TEdit
      Left = 70
      Height = 23
      Top = 44
      Width = 150
      TabOrder = 1
      Text = 'localhost'
    end
    object lblPort: TLabel
      Left = 240
      Height = 15
      Top = 48
      Width = 31
      Caption = 'Port:'
      ParentColor = False
    end
    object edtPort: TEdit
      Left = 290
      Height = 23
      Top = 44
      Width = 80
      TabOrder = 2
      Text = '5432'
    end
    object lblDatabase: TLabel
      Left = 16
      Height = 15
      Top = 80
      Width = 84
      Caption = 'Database/File:'
      ParentColor = False
    end
    object edtDatabase: TEdit
      Left = 110
      Height = 23
      Top = 76
      Width = 260
      TabOrder = 3
      Text = 'postgres'
    end
    object lblUser: TLabel
      Left = 16
      Height = 15
      Top = 112
      Width = 43
      Caption = 'User:'
      ParentColor = False
    end
    object edtUser: TEdit
      Left = 70
      Height = 23
      Top = 108
      Width = 120
      TabOrder = 4
      Text = 'postgres'
    end
    object lblPassword: TLabel
      Left = 210
      Height = 15
      Top = 112
      Width = 35
      Caption = 'Password:'
      ParentColor = False
    end
    object edtPassword: TEdit
      Left = 260
      Height = 23
      Top = 108
      Width = 110
      EchoMode = emPassword
      PasswordChar = '*'
      TabOrder = 5
      Text = ''
    end
    object lblSchema: TLabel
      Left = 16
      Height = 15
      Top = 144
      Width = 45
      Caption = 'Schema:'
      ParentColor = False
    end
    object edtSchema: TEdit
      Left = 70
      Height = 23
      Top = 140
      Width = 120
      TabOrder = 6
