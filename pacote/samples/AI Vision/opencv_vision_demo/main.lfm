object frmOpenCVVisionDemo: TfrmOpenCVVisionDemo
  Left = 320
  Height = 650
  Top = 150
  Width = 820
  Caption = 'TAIOpenCV & AI Vision Components Demonstration'
  ClientHeight = 650
  ClientWidth = 820
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  LCLVersion = '3.0.0.3'
  object pnlHeader: TPanel
    Left = 10
    Height = 50
    Top = 10
    Width = 800
    Align = alTop
    BorderSpacing.Around = 10
    ClientHeight = 50
    ClientWidth = 800
    TabOrder = 0
    object lblTitle: TLabel
      Left = 15
      Height = 25
      Top = 12
      Width = 500
      Caption = 'AI Vision Toolkit: OpenCV, Camera Capture & Tracking'
      Font.Height = -16
      Font.Style = [fsBold]
      ParentColor = False
    end
  end
  object pnlOpenCV: TPanel
    Left = 10
    Height = 120
    Top = 70
    Width = 790
    Align = alTop
    BorderSpacing.Left = 10
    BorderSpacing.Right = 20
    BorderSpacing.Bottom = 10
    ClientHeight = 120
    ClientWidth = 790
    TabOrder = 1
    object lblOpenCVTitle: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 200
      Caption = '1. OpenCV Library Binder (TAIOpenCV)'
      Font.Style = [fsBold]
      ParentColor = False
    end
    object btnLoadOpenCV: TButton
      Left = 15
      Height = 35
      Top = 40
      Width = 250
      Caption = 'Load OpenCV Dynamic Libraries'
      OnClick = btnLoadOpenCVClick
      TabOrder = 0
    end
    object lblOpenCVStatus: TLabel
      Left = 15
      Height = 15
      Top = 90
      Width = 300
      Caption = 'OpenCV Status: Not Loaded'
      ParentColor = False
    end
  end
  object pnlCamera: TPanel
    Left = 10
    Height = 120
    Top = 200
    Width = 250
    Align = alLeft
    BorderSpacing.Left = 10
    BorderSpacing.Right = 5
    BorderSpacing.Bottom = 10
    ClientHeight = 120
    ClientWidth = 250
    TabOrder = 2
    object lblCameraTitle: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 200
      Caption = '2. Camera Capture'
      Font.Style = [fsBold]
      ParentColor = False
    end
    object btnStartCamera: TButton
      Left = 15
      Height = 30
      Top = 35
      Width = 100
      Caption = 'Start Camera'
      OnClick = btnStartCameraClick
      TabOrder = 0
    end
    object btnStopCamera: TButton
      Left = 125
      Height = 30
      Top = 35
      Width = 100
      Caption = 'Stop Camera'
      OnClick = btnStopCameraClick
      TabOrder = 1
    end
    object lblCameraStatus: TLabel
      Left = 15
      Height = 15
      Top = 85
      Width = 200
      Caption = 'Camera: Stopped'
      ParentColor = False
    end
  end
  object pnlProcessing: TPanel
    Left = 265
    Height = 120
    Top = 200
    Width = 260
    Align = alLeft
    BorderSpacing.Left = 5
    BorderSpacing.Right = 5
    BorderSpacing.Bottom = 10
    ClientHeight = 120
    ClientWidth = 260
    TabOrder = 3
    object lblProcTitle: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 200
      Caption = '3. Frame Processing'
      Font.Style = [fsBold]
      ParentColor = False
    end
    object chkGrayscale: TCheckBox
      Left = 15
      Height = 19
      Top = 35
      Width = 150
      Caption = 'Convert to Grayscale'
      TabOrder = 0
    end
    object chkEqualize: TCheckBox
      Left = 15
      Height = 19
      Top = 60
      Width = 180
      Caption = 'Histogram Equalization'
      TabOrder = 1
    end
    object btnProcessFrame: TButton
      Left = 15
      Height = 25
      Top = 85
      Width = 220
      Caption = 'Process Manual Frame'
      OnClick = btnProcessFrameClick
      TabOrder = 2
    end
  end
  object pnlTracking: TPanel
    Left = 530
    Height = 120
    Top = 200
    Width = 280
    Align = alClient
    BorderSpacing.Left = 5
    BorderSpacing.Right = 10
    BorderSpacing.Bottom = 10
    ClientHeight = 120
    ClientWidth = 280
    TabOrder = 4
    object lblTrackTitle: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 200
      Caption = '4. Tracking & Analysis'
      Font.Style = [fsBold]
      ParentColor = False
    end
    object chkTrackFaces: TCheckBox
      Left = 15
      Height = 19
      Top = 35
      Width = 150
      Caption = 'Enable Face Tracking'
      TabOrder = 0
    end
    object chkTrackMotion: TCheckBox
      Left = 15
      Height = 19
      Top = 60
      Width = 150
      Caption = 'Enable Motion Tracking'
      TabOrder = 1
    end
    object lblTrackStatus: TLabel
      Left = 15
      Height = 15
      Top = 90
      Width = 250
      Caption = 'Tracking: Stopped'
      ParentColor = False
    end
  end
  object meLogs: TMemo
    Left = 10
    Height = 260
    Top = 380
    Width = 800
    Align = alBottom
    BorderSpacing.Around = 10
    ReadOnly = True
    ScrollBars = ssAutoBoth
    TabOrder = 5
  end
  object lblLogs: TLabel
    Left = 10
    Height = 15
    Top = 355
    Width = 120
    Caption = 'System Log / Activity:'
    ParentColor = False
  end
  object tmrCamera: TTimer
    Enabled = False
    Interval = 500
    OnTimer = tmrCameraTimer
    Left = 720
    Top = 15
  end
end
