object frmMain: TfrmMain
  Left = 150
  Height = 650
  Top = 100
  Width = 980
  Caption = 'TAIFrameProcessor Demo - Lazarus Native'
  ClientHeight = 650
  ClientWidth = 980
  OnCreate = FormCreate
  LCLVersion = '3.0.0.3'
  object pnlLeft: TPanel
    Left = 0
    Height = 650
    Top = 0
    Width = 420
    Align = alLeft
    BevelOuter = bvNone
    ClientHeight = 650
    ClientWidth = 420
    TabOrder = 0
    object btnLoad: TButton
      Left = 10
      Height = 30
      Top = 10
      Width = 120
      Caption = 'Carregar Imagem'
      TabOrder = 0
      OnClick = btnLoadClick
    end
    object btnProcess: TButton
      Left = 140
      Height = 30
      Top = 10
      Width = 120
      Caption = 'Processar Frame'
      TabOrder = 1
      OnClick = btnProcessClick
    end
    object btnSave: TButton
      Left = 270
      Height = 30
      Top = 10
      Width = 120
      Caption = 'Salvar Resultado'
      TabOrder = 2
      OnClick = btnSaveClick
    end
    object grpParameters: TGroupBox
      Left = 10
      Height = 150
      Top = 50
      Width = 400
      Caption = 'Ajustes de Escala / Grayscale'
      ClientHeight = 130
      ClientWidth = 396
      TabOrder = 3
      object lblScale: TLabel
        Left = 10
        Height = 15
        Top = 10
        Width = 100
        Caption = 'ScaleFactor:'
        ParentColor = False
      end
      object tbScaleFactor: TTrackBar
        Left = 120
        Height = 25
        Top = 5
        Width = 200
        Max = 20
        Min = 1
        Position = 10
        TabOrder = 0
        OnChange = tbScaleFactorChange
      end
      object lblScaleVal: TLabel
        Left = 330
        Height = 15
        Top = 10
        Width = 20
        Caption = '1.0'
        ParentColor = False
      end
      object chkGrayscale: TCheckBox
        Left = 10
        Height = 19
        Top = 45
        Width = 120
        Caption = 'Grayscale (Cinza)'
        TabOrder = 1
      end
      object chkModifyInput: TCheckBox
        Left = 160
        Height = 19
        Top = 45
        Width = 120
        Caption = 'ModifyInput'
        TabOrder = 2
      end
      object chkEnableChannelAdjustments: TCheckBox
        Left = 10
        Height = 19
        Top = 70
        Width = 220
        Caption = 'Habilitar Ajustes de Canais (EnableChannelAdjustments)'
        TabOrder = 3
      end
      object lblMode: TLabel
        Left = 10
        Height = 15
        Top = 102
        Width = 110
        Caption = 'RGBChannelMode:'
        ParentColor = False
      end
      object cbRGBChannelMode: TComboBox
        Left = 130
        Height = 23
        Top = 98
        Width = 150
        ItemHeight = 15
        ItemIndex = 0
        Items.Strings = (
          'None'
          'ExtractRed'
          'ExtractGreen'
          'ExtractBlue'
          'KeepRedOnly'
          'KeepGreenOnly'
          'KeepBlueOnly'
          'RemoveRed'
          'RemoveGreen'
          'RemoveBlue'
          'SwapRB'
          'SwapRG'
          'SwapGB'
          'RGBToBGR'
          'InvertRGB'
          'Custom'
        )
        Style = csDropDownList
        TabOrder = 4
        Text = 'None'
      end
    end
    object grpChannels: TGroupBox
      Left = 10
      Height = 350
      Top = 210
      Width = 400
      Caption = 'Operações Customizadas de Canal (RGB / Custom)'
      ClientHeight = 330
      ClientWidth = 396
      TabOrder = 4
      object chkRedEnabled: TCheckBox
        Left = 10
        Height = 19
        Top = 10
        Width = 100
        Caption = 'Red Enabled'
