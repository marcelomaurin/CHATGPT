        Max = 200
        Position = 100
        TabOrder = 4
      end
      object lblBlueGain: TLabel
        Left = 10
        Height = 15
        Top = 105
        Width = 60
        Caption = 'Blue Gain:'
        ParentColor = False
      end
      object tbBlueGain: TTrackBar
        Left = 110
        Height = 25
        Top = 100
        Width = 260
        Max = 200
        Position = 100
        TabOrder = 5
      end
      object lblRedOffset: TLabel
        Left = 10
        Height = 15
        Top = 145
        Width = 70
        Caption = 'Red Offset:'
        ParentColor = False
      end
      object tbRedOffset: TTrackBar
        Left = 110
        Height = 25
        Top = 140
        Width = 260
        Max = 255
        Min = -255
        Position = 0
        TabOrder = 6
      end
      object lblGreenOffset: TLabel
        Left = 10
        Height = 15
        Top = 175
        Width = 80
        Caption = 'Green Offset:'
        ParentColor = False
      end
      object tbGreenOffset: TTrackBar
        Left = 110
        Height = 25
        Top = 170
        Width = 260
        Max = 255
        Min = -255
        Position = 0
        TabOrder = 7
      end
      object lblBlueOffset: TLabel
        Left = 10
        Height = 15
        Top = 205
        Width = 70
        Caption = 'Blue Offset:'
        ParentColor = False
      end
      object tbBlueOffset: TTrackBar
        Left = 110
        Height = 25
        Top = 200
        Width = 260
        Max = 255
        Min = -255
        Position = 0
        TabOrder = 8
      end
      object chkInvertRed: TCheckBox
        Left = 10
        Height = 19
        Top = 240
        Width = 90
        Caption = 'Inverter Red'
        TabOrder = 9
