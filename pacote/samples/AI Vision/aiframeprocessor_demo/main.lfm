      object chkInvertGreen: TCheckBox
        Left = 130
        Height = 19
        Top = 240
        Width = 100
        Caption = 'Inverter Green'
        TabOrder = 10
      end
      object chkInvertBlue: TCheckBox
        Left = 250
        Height = 19
        Top = 240
        Width = 90
        Caption = 'Inverter Blue'
        TabOrder = 11
      end
      object ResetBtn: TButton
        Left = 10
        Height = 30
        Top = 280
        Width = 360
        Caption = 'Resetar Valores Padrão (ResetDefaults)'
        TabOrder = 12
        OnClick = ResetBtnClick
      end
    end
  end
  object pnlClient: TPanel
    Left = 420
    Height = 650
    Top = 0
    Width = 560
    Align = alClient
    BevelOuter = bvNone
    ClientHeight = 650
    ClientWidth = 560
    TabOrder = 1
    object pnlImages: TPanel
      Left = 0
      Height = 400
      Top = 0
      Width = 560
      Align = alTop
      BevelOuter = bvNone
      ClientHeight = 400
      ClientWidth = 560
      TabOrder = 0
      object imgOriginal: TImage
        Left = 10
        Height = 340
        Top = 30
        Width = 260
        Proportional = True
        Stretch = True
      end
      object imgProcessed: TImage
        Left = 290
        Height = 340
        Top = 30
        Width = 260
        Proportional = True
        Stretch = True
      end
      object lblOriginal: TLabel
        Left = 10
        Height = 15
        Top = 10
        Width = 100
        Caption = 'Imagem Original:'
        Font.Style = [fsBold]
        ParentColor = False
      end
      object lblProcessed: TLabel
        Left = 290
        Height = 15
        Top = 10
        Width = 120
        Caption = 'Imagem Processada:'
        Font.Style = [fsBold]
        ParentColor = False
      end
    end
    object pnlBottom: TPanel
      Left = 0
      Height = 250
      Top = 400
      Width = 560
      Align = alClient
      BevelOuter = bvNone
      ClientHeight = 250
      ClientWidth = 560
      TabOrder = 1
      object memoLog: TMemo
        Left = 10
        Height = 230
        Top = 10
        Width = 540
        Align = alClient
        BorderSpacing.Around = 10
        ReadOnly = True
        ScrollBars = ssAutoBoth
        TabOrder = 0
      end
    end
  end
  object OpenDialog1: TOpenDialog
    Filter = 'Imagens (*.png;*.jpg;*.jpeg;*.bmp)|*.png;*.jpg;*.jpeg;*.bmp'
    Left = 450
    Top = 200
  end
  object SaveDialog1: TSaveDialog
    Filter = 'JPEG (*.jpg)|*.jpg|PNG (*.png)|*.png|BMP (*.bmp)|*.bmp'
    Left = 520
    Top = 200
  end
end
