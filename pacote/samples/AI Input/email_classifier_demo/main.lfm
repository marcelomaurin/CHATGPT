object frmMain: TfrmMain
  Left = 300
  Height = 650
  Top = 150
  Width = 850
  Caption = 'Email Classifier Demo (aiemail)'
  ClientHeight = 650
  ClientWidth = 850
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  LCLVersion = '3.0.0.3'
  object pnlTop: TPanel
    Left = 10
    Height = 220
    Top = 10
    Width = 830
    Align = alTop
    BorderSpacing.Around = 10
    ClientHeight = 220
    ClientWidth = 830
    TabOrder = 0
    object grpConfig: TGroupBox
      Left = 10
      Height = 160
      Top = 10
      Width = 470
      Caption = ' Configurações de Conexão '
      ClientHeight = 140
      ClientWidth = 466
      TabOrder = 0
      object lblHostSMTP: TLabel
        Left = 10
        Height = 15
        Top = 10
        Width = 90
        Caption = 'SMTP Server Host'
        ParentColor = False
      end
      object editHostSMTP: TEdit
        Left = 10
        Height = 23
        Top = 30
        Width = 140
        TabOrder = 0
        Text = 'smtp.gmail.com'
      end
      object lblPortSMTP: TLabel
        Left = 160
        Height = 15
        Top = 10
        Width = 56
        Caption = 'SMTP Port'
        ParentColor = False
      end
      object editPortSMTP: TEdit
        Left = 160
        Height = 23
        Top = 30
        Width = 50
        TabOrder = 1
        Text = '25'
      end
      object lblHostPOP3: TLabel
        Left = 220
        Height = 15
        Top = 10
        Width = 91
        Caption = 'POP3 Server Host'
        ParentColor = False
      end
      object editHostPOP3: TEdit
        Left = 220
        Height = 23
        Top = 30
        Width = 140
        TabOrder = 2
        Text = 'pop.gmail.com'
      end
      object lblPortPOP3: TLabel
        Left = 370
        Height = 15
        Top = 10
        Width = 57
        Caption = 'POP3 Port'
        ParentColor = False
      end
      object editPortPOP3: TEdit
        Left = 370
        Height = 23
        Top = 30
        Width = 50
        TabOrder = 3
        Text = '110'
      end
      object lblUser: TLabel
        Left = 10
        Height = 15
        Top = 70
        Width = 53
        Caption = 'Username'
        ParentColor = False
      end
      object editUser: TEdit
        Left = 10
        Height = 23
        Top = 90
        Width = 200
        TabOrder = 4
        Text = 'marcelomaurinmartins@gmail.com'
      end
      object lblPass: TLabel
        Left = 220
        Height = 15
        Top = 70
        Width = 50
        Caption = 'Password'
        ParentColor = False
      end
      object editPass: TEdit
        Left = 220
        Height = 23
        Top = 90
        Width = 200
        EchoMode = emPassword
        PasswordChar = '*'
        TabOrder = 5
        Text = ''
      end
    end
    object grpActions: TGroupBox
      Left = 490
      Height = 160
      Top = 10
      Width = 330
      Caption = ' Ações '
      ClientHeight = 140
      ClientWidth = 326
      TabOrder = 1
      object lblTo: TLabel
        Left = 10
        Height = 15
        Top = 10
        Width = 115
        Caption = 'Recipient (Test Send)'
        ParentColor = False
      end
      object editTo: TEdit
        Left = 10
        Height = 23
        Top = 30
        Width = 300
        TabOrder = 0
        Text = 'marcelomaurinmartins@gmail.com'
      end
      object btnSend: TButton
        Left = 10
        Height = 30
        Top = 70
        Width = 140
        Caption = '1. Send Test Email'
        OnClick = btnSendClick
        TabOrder = 1
      end
      object btnFetch: TButton
        Left = 160
        Height = 30
        Top = 70
        Width = 150
        Caption = '2. Fetch && Classify'
        OnClick = btnFetchClick
        TabOrder = 2
      end
      object btnClearLog: TButton
        Left = 10
        Height = 30
        Top = 110
        Width = 140
        Caption = 'Clear Log'
        OnClick = btnClearLogClick
        TabOrder = 3
      end
    end
    object lblStatus: TLabel
      Left = 15
      Height = 15
      Top = 185
      Width = 400
      Caption = 'Status: Ready'
      Font.Style = [fsBold]
      ParentColor = False
    end
  end
  object memoLog: TMemo
    Left = 10
    Height = 390
    Top = 250
    Width = 830
    Align = alClient
    BorderSpacing.Around = 10
    Font.Name = 'Consolas'
    ScrollBars = ssAutoBoth
    TabOrder = 1
  end
end
