object frmMain: TfrmMain
  Left = 300
  Height = 600
  Top = 150
  Width = 800
  Caption = 'Webserver Demo (aiwebserver)'
  ClientHeight = 600
  ClientWidth = 800
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  LCLVersion = '3.0.0.3'
  object pnlTop: TPanel
    Left = 10
    Height = 180
    Top = 10
    Width = 780
    Align = alTop
    BorderSpacing.Around = 10
    ClientHeight = 180
    ClientWidth = 780
    TabOrder = 0
    object grpConfig: TGroupBox
      Left = 10
      Height = 110
      Top = 10
      Width = 200
      Caption = ' Configurações do Servidor '
      ClientHeight = 90
      ClientWidth = 196
      TabOrder = 0
      object lblPort: TLabel
        Left = 10
        Height = 15
        Top = 10
        Width = 80
        Caption = 'Server Port'
        ParentColor = False
      end
      object editPort: TEdit
        Left = 10
        Height = 23
        Top = 30
        Width = 140
        TabOrder = 0
        Text = '8086'
      end
    end
    object grpActions: TGroupBox
      Left = 220
      Height = 110
      Top = 10
      Width = 550
      Caption = ' Controles do Servidor '
      ClientHeight = 90
      ClientWidth = 546
      TabOrder = 1
      object btnStartServer: TButton
        Left = 10
        Height = 30
        Top = 30
        Width = 160
        Caption = 'Start Web Server'
        OnClick = btnStartServerClick
        TabOrder = 0
      end
      object btnStopServer: TButton
        Left = 180
        Height = 30
        Top = 30
        Width = 160
        Caption = 'Stop Web Server'
        OnClick = btnStopServerClick
        TabOrder = 1
      end
      object btnClearLog: TButton
        Left = 350
        Height = 30
        Top = 30
        Width = 100
        Caption = 'Clear Log'
        OnClick = btnClearLogClick
        TabOrder = 2
      end
    end
    object lblStatus: TLabel
      Left = 15
      Height = 15
      Top = 145
      Width = 400
      Caption = 'Status: Ready'
      Font.Style = [fsBold]
      ParentColor = False
    end
  end
  object memoLog: TMemo
    Left = 10
    Height = 390
    Top = 200
    Width = 780
    Align = alClient
    BorderSpacing.Around = 10
    Font.Name = 'Consolas'
    ScrollBars = ssAutoBoth
    TabOrder = 1
  end
  object AIWebAPIServer1: TAIWebAPIServer
    Left = 400
    Top = 135
  end
end
