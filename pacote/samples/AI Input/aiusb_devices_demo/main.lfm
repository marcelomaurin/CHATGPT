object frmMain: TfrmMain
  Left = 200
  Height = 600
  Top = 100
  Width = 900
  Caption = 'AIUSB Devices Demo'
  ClientHeight = 600
  ClientWidth = 900
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  object pnlTop: TPanel
    Left = 0
    Height = 60
    Top = 0
    Width = 900
    Align = alTop
    ClientHeight = 60
    ClientWidth = 900
    TabOrder = 0
    object btnRefresh: TButton
      Left = 10
      Height = 30
      Top = 15
      Width = 100
      Caption = 'Refresh'
      OnClick = btnRefreshClick
      TabOrder = 0
    end
    object chkAutoRefresh: TCheckBox
      Left = 130
      Height = 19
      Top = 20
      Width = 95
      Caption = 'Auto Refresh'
      OnChange = chkAutoRefreshChange
      TabOrder = 1
    end
    object lblInterval: TLabel
      Left = 250
      Height = 15
      Top = 22
      Width = 72
      Caption = 'Interval (ms):'
      ParentColor = False
    end
    object editInterval: TEdit
      Left = 330
      Height = 23
      Top = 18
      Width = 60
      OnChange = editIntervalChange
      TabOrder = 2
      Text = '2000'
    end
  end
  object gridDevices: TStringGrid
    Left = 0
    Height = 340
    Top = 60
    Width = 900
    Align = alClient
    FixedCols = 0
    TabOrder = 1
  end
  object memoLog: TMemo
    Left = 0
    Height = 200
    Top = 400
    Width = 900
    Align = alBottom
    ReadOnly = True
    ScrollBars = ssAutoVertical
    TabOrder = 2
  end
end
