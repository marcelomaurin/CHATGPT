        end
      end
      object meOriginalCode: TMemo
        Left = 0
        Height = 607
        Top = 60
        Width = 450
        Align = alLeft
        Font.CharSet = ANSI_CHARSET
        Font.Name = 'Courier New'
        Font.Pitch = fpFixed
        Font.Quality = fqDraft
        Lines.Strings = (
          'procedure ProcessList;'
          'var'
          '  i: Integer;'
          '  L: TStringList;'
          'begin'
          '  L := TStringList.Create;'
          '  for i := 0 to 100 do'
          '  begin'
          '    L.Add(IntToStr(i));'
          '  end;'
          '  // Vazamento de memória proposital'
          'end;'
        )
        ParentFont = False
        ScrollBars = ssAutoBoth
        TabOrder = 1
      end
