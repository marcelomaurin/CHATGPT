    end
    object edEpochs: TEdit
      Left = 15
      Height = 23
      Top = 85
      Width = 190
      TabOrder = 1
      Text = '100'
    end
    object btnGenerateData: TButton
      Left = 15
      Height = 35
      Top = 130
      Width = 190
      Caption = 'Gerar Série Temporal'
