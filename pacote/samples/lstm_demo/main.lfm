object frmLSTMDemo: TfrmLSTMDemo
  Left = 320
  Height = 620
  Top = 150
  Width = 820
  Caption = 'TLSTMPredictor Showcase - Previsão de Tendências com Rede LSTM'
  ClientHeight = 620
  ClientWidth = 820
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  LCLVersion = '3.0.0.3'
  object pnlConfig: TPanel
    Left = 10
    Height = 115
    Top = 10
    Width = 800
    Align = alTop
    BorderSpacing.Around = 10
    ClientHeight = 115
    ClientWidth = 800
    TabOrder = 0
    object lblDLLPath: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 280
      Caption = 'Escolha a DLL do Python:'
      ParentColor = False
    end
    object lbDLLs: TListBox
      Left = 15
      Height = 70
      Top = 30
      Width = 280
      ItemHeight = 0
      TabOrder = 0
    end
    object btnInitPython: TButton
      Left = 310
      Height = 35
      Top = 35
      Width = 200
      Caption = 'Ativar Python'
      OnClick = btnInitPythonClick
      TabOrder = 1
    end
    object btnInstallDeps: TButton
      Left = 520
      Height = 35
      Top = 35
      Width = 260
      Caption = 'Instalar Dependências (Pip)'
      OnClick = btnInstallDepsClick
      TabOrder = 2
    end
  end
  object pnlTrain: TPanel
    Left = 10
    Height = 340
    Top = 110
    Width = 220
    Align = alLeft
