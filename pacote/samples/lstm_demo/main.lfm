    BorderSpacing.Right = 10
    BorderSpacing.Bottom = 10
    ClientHeight = 340
    ClientWidth = 240
    TabOrder = 2
    object lblActualList: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 59
