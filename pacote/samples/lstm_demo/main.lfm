      TabOrder = 3
    end
    object btnPredict: TButton
      Left = 15
      Height = 35
      Top = 230
      Width = 190
      Caption = 'Prever Próximos Passos'
      Font.Style = [fsBold]
      OnClick = btnPredictClick
      TabOrder = 4
    end
  end
  object pnlLists: TPanel
    Left = 570
    Height = 340
    Top = 110
    Width = 240
    Align = alRight
