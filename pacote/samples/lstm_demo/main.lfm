    BorderSpacing.Right = 5
    BorderSpacing.Bottom = 10
    ClientHeight = 340
    ClientWidth = 220
    TabOrder = 1
    object lblWindowSize: TLabel
      Left = 15
      Height = 15
      Top = 10
      Width = 100
