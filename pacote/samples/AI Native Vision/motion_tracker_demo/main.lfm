  object OpenDialog1: TOpenDialog
    Title = 'Carregar Frame'
    Filter = 'Imagens Suportadas (*.bmp;*.png;*.jpg;*.jpeg)|*.bmp;*.png;*.jpg;*.jpeg|Todos Arquivos (*.*)|*.*'
