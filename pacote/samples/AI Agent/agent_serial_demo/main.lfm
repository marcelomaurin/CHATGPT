  object CHATGPT1: TCHATGPT
    Prompt = 'VocÃª Ã© um assistente.'
    Dev = 'Voc'#195#170' '#195#169' um assistente.'
    TipoChat = VCT_GPT4o
    Provider = AIP_OPENAI
    LocalIP = 'http://localhost:11434'
    MaxTokens = 4096
    Left = 680
    Top = 680
  end
  object AISerialModem1: TAISerialModem
    Prompt = 'Component TAISerialModem handles serial communication. Use OpenPort, ClosePort, WriteText, ReadText and Poll. Events: OnConnect, OnDisconnect, OnRXReceive and OnTXSend. AI Agent: Use this to interface legacy hardware, sensors and microcontrollers.'
    DeviceName = 'COM1'
    OnRXReceive = SerialRX
    Left = 760
    Top = 680
  end
  object AIListSerialDevices1: TAIListSerialDevices
    Prompt = 'Component TAIListSerialDevices queries and aggregates available serial hardware interfaces (COM/tty) on Windows and Linux/macOS. Methods: Refresh, GetDeviceNames(AList: TStrings).'
    Devices = <>
    Left = 840
    Top = 600
  end
  object AIAgentDeviceCommands1: TAIAgentAction
    Left = 840
    Top = 680
  end
  object AIAgentSerial1: TAIAgentSerial
    Prompt = 'Agent that connects TCHATGPT to TAISerialModem using confirmed JSON actions, serial polling and RX context.'
    Category = ccAction
    Serial = AISerialModem1
    LLM = CHATGPT1
    CommandCatalog = AIAgentDeviceCommands1
    AutoDiscoverCommands = True
    DiscoveryCommand = 'MAN'
    ManualBeginMarker = 'MAN-BEGIN'
    ManualEndMarker = 'MAN-END'
    CommandLinePrefix = 'COMMAND '
    AllowUnknownDeviceCommands = False
    OnBeforeAction = AgentBeforeAction
    OnAgentLog = AgentLog
    OnCommandsDiscovered = AgentCommandsDiscovered
    OnCommandRejected = AgentCommandRejected
    OnDiscoveryError = AgentDiscoveryError
    Left = 880
    Top = 680
  end
  object AIAgentMemoryMap1: TAIAgentMemoryMap
    Left = 920
    Top = 680
  end
  object tmrSerialPoll: TTimer
    Enabled = True
    Interval = 50
