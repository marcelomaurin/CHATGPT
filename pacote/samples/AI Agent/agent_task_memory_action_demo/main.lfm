    object lblProvider: TLabel
      Left = 5
      Height = 40
      Top = 5
      Width = 60
      Align = alLeft
      Caption = ' Provedor: '
      Layout = tlCenter
    end
    object cbProvider: TComboBox
      Left = 65
      Height = 23
      Top = 13
      Width = 100
      ItemHeight = 15
      Items.Strings = (
        'OpenAI'
        'Local (Ollama/LMStudio)'
      )
      OnChange = cbProviderChange
      Style = csDropDownList
      TabOrder = 0
    end
    object lblModel: TLabel
      Left = 175
      Height = 40
      Top = 5
      Width = 55
      Align = alLeft
      Caption = ' Modelo: '
      Layout = tlCenter
    end
    object cbModel: TComboBox
      Left = 230
      Height = 23
      Top = 13
      Width = 120
      ItemHeight = 15
      Items.Strings = (
        'gpt-4o-mini'
        'gpt-4o'
        'llama3.2'
        'deepseek-r1'
      )
      TabOrder = 1
      Text = 'gpt-4o-mini'
    end
    object lblToken: TLabel
      Left = 360
      Height = 40
      Top = 5
      Width = 45
      Align = alLeft
      Caption = ' Token: '
      Layout = tlCenter
    end
    object edtToken: TEdit
      Left = 410
      Height = 23
      Top = 13
      Width = 150
      EchoMode = emPassword
      PasswordChar = '*'
      TabOrder = 2
    end
    object lblBaseURL: TLabel
      Left = 570
      Height = 40
      Top = 5
      Width = 60
      Align = alLeft
      Caption = ' Base URL: '
      Layout = tlCenter
    end
    object edtBaseURL: TEdit
      Left = 630
      Height = 23
      Top = 13
      Width = 180
      TabOrder = 3
      Text = 'https://api.openai.com/v1'
    end
  end
