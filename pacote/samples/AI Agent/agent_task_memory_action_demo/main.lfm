  OnDestroy = FormDestroy
  LCLVersion = '2.2.0'
  object pnlHeader: TPanel
    Left = 0
    Height = 50
    Top = 0
    Width = 1200
    Align = alTop
    BevelOuter = bvNone
    BorderWidth = 5
    ClientHeight = 50
    ClientWidth = 1200
