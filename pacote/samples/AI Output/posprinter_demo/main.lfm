        Left = 480
        Height = 23
        Top = 33
        Width = 175
        TabOrder = 3
        Text = 'saida.bin'
      end
      object lblPort: TLabel
        Left = 665
        Height = 15
        Top = 15
        Width = 70
        Caption = 'Baud / Porta:'
