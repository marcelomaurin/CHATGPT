  object memoLog: TMemo
    Left = 0
    Height = 465
    Top = 235
    Width = 1040
    Align = alClient
    Font.Name = 'Courier New'
    ParentFont = False
    ReadOnly = True
    ScrollBars = ssAutoBoth
