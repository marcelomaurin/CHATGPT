        Width = 170
        ItemHeight = 15
        ItemIndex = 2
        Items.Strings = (
          'Serial (COM)'
          'Ethernet (TCP 9100)'
          'Device / Arquivo'
          'Impressora do SO (RAW)'
        )
        Style = csDropDownList
        TabOrder = 2
        Text = 'Device / Arquivo'
        OnChange = cmbInterfaceChange
      end
      object lblDevice: TLabel
        Left = 480
        Height = 15
        Top = 15
        Width = 116
        Caption = 'Porta / IP / Caminho:'
