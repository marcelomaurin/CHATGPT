object frmMain: TfrmMain
  Left = 250
  Height = 700
  Top = 120
  Width = 1040
  Caption = 'Posprinter Demo (aiposprinter)'
  ClientHeight = 700
  ClientWidth = 1040
  LCLVersion = '4.4.0.0'
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  object pnlTop: TPanel
    Left = 0
    Height = 235
    Top = 0
    Width = 1040
    Align = alTop
    BevelOuter = bvNone
    ClientHeight = 235
    ClientWidth = 1040
    TabOrder = 0
    object lblTitle: TLabel
      Left = 15
      Height = 25
      Top = 10
      Width = 264
      Caption = 'Posprinter Demo (aiposprinter)'
      Font.Height = -18
      Font.Style = [fsBold]
      ParentColor = False
      ParentFont = False
    end
    object lblStatus: TLabel
      Left = 320
      Height = 15
      Top = 18
      Width = 90
      Caption = 'Status: Pronto'
      ParentColor = False
    end
    object lblModel: TLabel
      Left = 15
      Height = 15
      Top = 45
      Width = 45
      Caption = 'Modelo:'
      ParentColor = False
    end
    object cmbModel: TComboBox
      Left = 15
      Height = 23
      Top = 63
      Width = 155
      ItemHeight = 15
      ItemIndex = 0
      Items.Strings = (
        'Elgin i9 (80mm)'
        'QR203 (58mm)'
        'Elgin L42DT (Label)'
      )
      Style = csDropDownList
      TabOrder = 0
      Text = 'Elgin i9 (80mm)'
      OnChange = cmbModelChange
    end
    object lblProtocol: TLabel
      Left = 180
      Height = 15
      Top = 45
      Width = 57
      Caption = 'Protocolo:'
      ParentColor = False
    end
    object cmbProtocol: TComboBox
      Left = 180
      Height = 23
      Top = 63
      Width = 110
      ItemHeight = 15
      ItemIndex = 0
      Items.Strings = (
        'ESC/POS'
        'Native OS'
        'EPL'
        'ZPL'
        'TSPL'
      )
      Style = csDropDownList
      TabOrder = 1
      Text = 'ESC/POS'
      OnChange = cmbProtocolChange
    end
    object lblInterface: TLabel
      Left = 300
      Height = 15
      Top = 45
      Width = 52
      Caption = 'Interface:'
      ParentColor = False
    end
    object cmbInterface: TComboBox
      Left = 300
      Height = 23
      Top = 63
      Width = 170
      ItemHeight = 15
      ItemIndex = 2
      Items.Strings = (
        'Serial (COM)'
        'Ethernet (TCP 9100)'
        'Device / Arquivo'
        'Impressora do SO (RAW)'
      )
      Style = csDropDownList
      TabOrder = 2
      Text = 'Device / Arquivo'
      OnChange = cmbInterfaceChange
    end
    object lblDevice: TLabel
      Left = 480
      Height = 15
      Top = 45
      Width = 116
      Caption = 'Porta / IP / Caminho:'
      ParentColor = False
    end
    object edtDevice: TEdit
      Left = 480
      Height = 23
      Top = 63
      Width = 175
      TabOrder = 3
      Text = 'saida.bin'
    end
    object lblPort: TLabel
      Left = 665
      Height = 15
      Top = 45
      Width = 70
      Caption = 'Baud / Porta:'
      ParentColor = False
    end
    object edtPort: TEdit
      Left = 665
      Height = 23
      Top = 63
      Width = 75
      TabOrder = 4
      Text = '9100'
    end
    object lblPrinterSO: TLabel
      Left = 750
      Height = 15
      Top = 45
      Width = 62
      Caption = 'Fila do SO:'
      ParentColor = False
    end
    object cmbPrinterSO: TComboBox
      Left = 750
      Height = 23
      Top = 63
      Width = 200
      ItemHeight = 15
      Style = csDropDownList
      TabOrder = 5
    end
    object btnRefreshPrinters: TButton
      Left = 958
      Height = 23
      Top = 63
      Width = 68
      Caption = 'Atualizar'
      TabOrder = 6
      OnClick = btnRefreshPrintersClick
    end
    object lblLabelW: TLabel
      Left = 15
      Height = 15
      Top = 100
      Width = 88
      Caption = 'Etiqueta L (mm):'
      ParentColor = False
    end
    object spLabelW: TSpinEdit
      Left = 15
      Height = 23
      Top = 118
      Width = 75
      MaxValue = 300
      MinValue = 10
      TabOrder = 7
      Value = 100
    end
    object lblLabelH: TLabel
      Left = 100
      Height = 15
      Top = 100
      Width = 45
      Caption = 'A (mm):'
