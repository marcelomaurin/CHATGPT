object frmMain: TfrmMain
  Left = 250
  Height = 720
  Top = 110
  Width = 1040
  Caption = 'Posprinter Demo (aiposprinter)'
  ClientHeight = 720
  ClientWidth = 1040
  LCLVersion = '4.4.0.0'
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  object pgConfig: TPageControl
    Left = 0
    Height = 215
    Top = 0
    Width = 1040
    ActivePage = tabPrinter
    Align = alTop
    TabIndex = 0
    TabOrder = 0
    object tabPrinter: TTabSheet
      Caption = 'Impressora'
      ClientHeight = 187
      ClientWidth = 1032
      object lblModel: TLabel
        Left = 15
        Height = 15
        Top = 15
        Width = 45
        Caption = 'Modelo:'
        ParentColor = False
      end
      object cmbModel: TComboBox
        Left = 15
        Height = 23
        Top = 33
        Width = 155
        ItemHeight = 15
        ItemIndex = 0
        Items.Strings = (
          'Elgin i9 (80mm)'
          'QR203 (58mm)'
          'Elgin L42DT (Label)'
        )
        Style = csDropDownList
        TabOrder = 0
        Text = 'Elgin i9 (80mm)'
        OnChange = cmbModelChange
      end
      object lblProtocol: TLabel
        Left = 180
        Height = 15
        Top = 15
        Width = 57
        Caption = 'Protocolo:'
        ParentColor = False
      end
      object cmbProtocol: TComboBox
        Left = 180
        Height = 23
        Top = 33
        Width = 110
        ItemHeight = 15
        ItemIndex = 0
        Items.Strings = (
          'ESC/POS'
          'Native OS'
          'EPL'
          'ZPL'
          'TSPL'
        )
        Style = csDropDownList
        TabOrder = 1
        Text = 'ESC/POS'
        OnChange = cmbProtocolChange
      end
      object lblInterface: TLabel
        Left = 300
        Height = 15
        Top = 15
        Width = 52
        Caption = 'Interface:'
        ParentColor = False
