    object tabPaper: TTabSheet
      Caption = 'Tamanho do papel'
      ClientHeight = 187
      ClientWidth = 1032
      object gbPhysical: TGroupBox
        Left = 15
        Height = 155
        Top = 10
        Width = 245
        Caption = ' Papel / etiqueta (fisico) '
        ClientHeight = 135
        ClientWidth = 241
        TabOrder = 0
        object lblPaperW: TLabel
          Left = 15
          Height = 15
          Top = 12
          Width = 70
          Caption = 'Largura (mm):'
          ParentColor = False
        end
        object spPaperW: TFloatSpinEdit
          Left = 120
          Height = 23
          Top = 8
          Width = 100
          DecimalPlaces = 1
          Increment = 1
          MaxValue = 300
          MinValue = 10
          TabOrder = 0
          Value = 51
          OnChange = GeometryChange
        end
        object lblPaperH: TLabel
          Left = 15
          Height = 15
          Top = 43
          Width = 62
