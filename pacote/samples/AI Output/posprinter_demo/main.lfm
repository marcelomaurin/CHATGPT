  object memoLog: TMemo
    Left = 0
    Height = 505
    Top = 215
    Width = 1040
    Align = alClient
    Font.Name = 'Courier New'
    ParentFont = False
    ReadOnly = True
    ScrollBars = ssAutoBoth
    TabOrder = 1
