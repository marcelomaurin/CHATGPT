  object AIGraphMap1: TAIGraphMap
    Prompt = 'Component TAIGraphMap creates a weighted token graph for explainable text classification. It tokenizes input texts, creates token nodes and category nodes, connects them with weighted edges, trains from InputText and OutputCategory pairs, saves and loads the graph as JSON, and predicts the closest output category for a new text with a ranked percentage list.'
    Training = <>
    TokenDelimiterChars = ' ,;.:!?()[]{}''"/\@#$*&^%-_+='
    StopWords.Strings = (
      'a'
      'o'
      'as'
      'os'
      'um'
      'uma'
      'de'
      'do'
      'da'
      'dos'
      'das'
      'e'
      'em'
      'com'
      'para'
      'por'
      'ao'
      'na'
      'no'
      'que'
      'se'
      'nao'
    )
    TokenEdgeWeight = 1
    CategoryEdgeWeight = 2
    RepetitionBoost = 1
    DepthDecay = 0.6
    MinimumScore = 0.01
    UnknownCategoryName = 'unknown'
    Left = 48
    Top = 24
  end
  object AITrainingExporter1: TAITrainingExporter
    Prompt = 'Component TAITrainingExporter collects, organizes, validates, and exports training data from TAIGraphMap into CSV, CSV ranking, JSON, JSONL, CSV numeric, Graph JSON, GraphViz DOT, TXT, and ARFF formats.'
    GraphMap = AIGraphMap1
    ExportFormat = efCSV
    VectorizationMode = vmBinary
    OneHotOutput = True
    TargetFileName = 'training_export.csv'
    Overwrite = True
    Left = 144
    Top = 24
  end
  object odDataset: TOpenDialog
    Filter = 'JSON files (*.json)|*.json|All files (*.*)|*.*'
    Options = [ofFileMustExist, ofPathMustExist, ofEnableSizing]
    Title = 'Open dataset JSON'
    Left = 240
    Top = 24
  end
  object sdExport: TSaveDialog
    Filter = 'All files (*.*)|*.*'
    Options = [ofOverwritePrompt, ofEnableSizing]
    Title = 'Save export file'
    Left = 336
    Top = 24
  end
end
