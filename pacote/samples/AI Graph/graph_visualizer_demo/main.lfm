  object memoLog: TMemo
    Left = 10
    Height = 180
    Top = 410
    Width = 780
    Align = alBottom
    BorderSpacing.Around = 10
    ScrollBars = ssAutoBoth
    TabOrder = 2
  end
  object AIGraphMap1: TAIGraphMap
    Prompt = 'Component TAIGraphMap creates a weighted token graph for explainable text classification. It tokenizes input texts, creates token nodes and category nodes, connects them with weighted edges, trains from InputText and OutputCategory pairs, saves and loads the graph as JSON, and predicts the closest output category for a new text with a ranked percentage list.'
    Training = <>
    TokenDelimiterChars = ' ,;.:!?()[]{}''"/\@#$*&^%-_+='
    StopWords.Strings = (
      'a'
      'o'
      'as'
      'os'
      'um'
      'uma'
      'de'
      'do'
      'da'
      'dos'
      'das'
      'e'
      'em'
      'com'
      'para'
      'por'
      'ao'
      'na'
      'no'
      'que'
      'se'
      'nao'
      'não'
    )
    TokenEdgeWeight = 1
    CategoryEdgeWeight = 2
    RepetitionBoost = 1
    DepthDecay = 0.6
    MinimumScore = 0.01
    UnknownCategoryName = 'unknown'
    Left = 176
    Top = 40
  end
  object AIGraphVisualizer1: TAIGraphVisualizer
    Prompt = 'Component TAIGraphVisualizer formats and filters the TAIGraphMap knowledge network of token-to-token and token-to-category associations. It exports subgraph structures into standard visualization formats including GraphViz DOT, Mermaid flowchart syntax, JSON objects, and flat text summaries.'
    GraphMap = AIGraphMap1
    TopN = 50
    MinWeight = 0.1
    Left = 88
    Top = 40
  end
end
