object frmMain: TfrmMain
  Left = 320
  Height = 650
  Top = 120
  Width = 900
  Caption = 'AITestLLM - Avaliador de Prompts'
  ClientHeight = 650
  ClientWidth = 900
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  object pgcMain: TPageControl
    Left = 10
    Height = 630
    Top = 10
    Width = 880
    ActivePage = tsConfig
    Align = alClient
    BorderSpacing.Around = 10
    TabIndex = 0
    TabOrder = 0
    object tsConfig: TTabSheet
      Caption = '1. Configurações LLM'
      ClientHeight = 602
      ClientWidth = 872
      object lblTitle: TLabel
        Left = 15
        Height = 25
        Top = 15
        Width = 338
        Caption = 'Configuração do Componente ChatGPT'
        Font.Height = -18
        Font.Name = 'Segoe UI'
        Font.Style = [fsBold]
        ParentColor = False
        ParentFont = False
      end
      object lblProvider: TLabel
        Left = 15
        Height = 15
        Top = 65
        Width = 87
        Caption = 'Provedor (Engine):'
        ParentColor = False
      end
      object cbProvider: TComboBox
        Left = 140
        Height = 23
        Top = 60
        Width = 250
        ItemHeight = 15
        Style = csDropDownList
        TabOrder = 0
        OnChange = cbProviderChange
      end
      object lblModel: TLabel
        Left = 15
        Height = 15
        Top = 100
        Width = 44
        Caption = 'Modelo:'
        ParentColor = False
      end
      object cbModel: TComboBox
        Left = 140
        Height = 23
        Top = 95
        Width = 250
        ItemHeight = 15
        Style = csDropDownList
        TabOrder = 1
      end
      object lblCustomModel: TLabel
        Left = 15
        Height = 15
        Top = 135
        Width = 105
        Caption = 'Modelo Customizado:'
        ParentColor = False
      end
      object edtCustomModel: TEdit
        Left = 140
        Height = 23
        Top = 130
        Width = 250
        TabOrder = 2
      end
      object lblURL: TLabel
        Left = 15
        Height = 15
        Top = 170
        Width = 81
        Caption = 'URL Customizada:'
        ParentColor = False
      end
      object edtURL: TEdit
        Left = 140
        Height = 23
        Top = 165
        Width = 250
        TabOrder = 3
      end
      object lblLocalIP: TLabel
        Left = 15
        Height = 15
        Top = 205
        Width = 99
        Caption = 'IP Local / Ollama URL:'
        ParentColor = False
      end
      object edtLocalIP: TEdit
        Left = 140
        Height = 23
        Top = 200
        Width = 250
        TabOrder = 4
      end
      object lblToken: TLabel
        Left = 15
        Height = 15
        Top = 240
        Width = 87
        Caption = 'Token / API Key:'
        ParentColor = False
      end
      object edtToken: TEdit
        Left = 140
        Height = 23
        Top = 235
        Width = 400
        EchoMode = emPassword
        PasswordChar = '*'
        TabOrder = 5
      end
      object lblMaxTokens: TLabel
        Left = 15
        Height = 15
        Top = 275
        Width = 66
        Caption = 'Max Tokens:'
        ParentColor = False
      end
      object edtMaxTokens: TEdit
        Left = 140
        Height = 23
        Top = 270
        Width = 100
        TabOrder = 6
        Text = '4096'
      end
      object chkUseLLMValidation: TCheckBox
        Left = 15
        Height = 19
        Top = 315
        Width = 328
        Caption = 'Usar validação semântica com a própria LLM'
        TabOrder = 7
        OnChange = chkUseLLMValidationChange
      end
      object lblValidationPrompt: TLabel
        Left = 15
        Height = 15
        Top = 345
        Width = 162
        Caption = 'Prompt do Validador Semântico:'
        ParentColor = False
      end
      object memValidationPrompt: TMemo
        Left = 15
        Height = 100
        Top = 365
        Width = 840
        Lines.Strings = (
          'Você é um avaliador de correspondência de respostas. Responda apenas "SIM" ou "NAO".'
          'Sua função é analisar se a resposta obtida pela LLM atende semanticamente ao que era esperado pelo teste.'
        )
        ScrollBars = ssAutoVertical
        TabOrder = 8
      end
      object btnSaveConfig: TButton
        Left = 15
        Height = 35
        Top = 480
        Width = 150
        Caption = 'Salvar Configurações'
        TabOrder = 9
        OnClick = btnSaveConfigClick
      end
    end
    object tsQuestions: TTabSheet
      Caption = '2. Banco de Testes (JSON)'
      ClientHeight = 602
      ClientWidth = 872
      object lblJSONFile: TLabel
        Left = 15
        Height = 15
        Top = 20
        Width = 79
        Caption = 'Arquivo JSON:'
        ParentColor = False
      end
      object edtJSONFile: TEdit
        Left = 105
        Height = 23
        Top = 15
        Width = 590
        ReadOnly = True
        TabOrder = 0
      end
      object btnSelectJSON: TButton
        Left = 705
        Height = 25
        Top = 14
        Width = 150
        Caption = 'Selecionar JSON...'
        TabOrder = 1
        OnClick = btnSelectJSONClick
      end
      object gridTests: TStringGrid
        Left = 15
        Height = 480
        Top = 60
        Width = 840
        ColCount = 5
        Columns = <        
          item
            Title.Caption = 'Descrição (Resumo)'
            Width = 150
          end        
          item
            Title.Caption = 'DEV (System)'
            Width = 180
          end        
          item
            Title.Caption = 'PROMPT (Pergunta)'
            Width = 200
          end        
          item
            Title.Caption = 'Resposta Esperada'
            Width = 180
          end        
          item
            Title.Caption = 'Respostas Válidas'
            Width = 110
          end>
        FixedCols = 0
        Options = [goFixedVertLine, goFixedHorzLine, goVertLine, goHorzLine, goRangeSelect, goRowSelect, goSmoothScroll]
        TabOrder = 2
        OnSelection = gridTestsSelection
      end
      object btnReloadJSON: TButton
        Left = 15
        Height = 30
        Top = 550
        Width = 150
        Caption = 'Recarregar JSON'
        TabOrder = 3
        OnClick = btnReloadJSONClick
      end
    end
