  object ChatGPT1: TCHATGPT
    Prompt = 'Você é um assistente.'
    Dev = 'Você é um assistente.'
    TipoChat = VCT_GPT4o
    Provider = AIP_OPENAI
    LocalIP = 'http://localhost:11434'
    MaxTokens = 4096
    Left = 750
    Top = 50
  end
  object OpenDialog1: TOpenDialog
    DefaultExt = '.json'
    Filter = 'Arquivos JSON (*.json)|*.json|Todos os Arquivos (*.*)|*.*'
    Left = 810
    Top = 50
  end
end
