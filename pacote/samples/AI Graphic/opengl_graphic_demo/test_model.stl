solid test_pyramid
  facet normal 0 0 -1
    outer loop
      vertex -1 -1 0
      vertex 1 -1 0
      vertex 1 1 0
    endloop
  endfacet
  facet normal 0 0 -1
    outer loop
      vertex -1 -1 0
      vertex 1 1 0
      vertex -1 1 0
    endloop
  endfacet
  facet normal -0.7 0 0.7
    outer loop
      vertex -1 -1 0
      vertex 0 0 1.5
      vertex -1 1 0
    endloop
  endfacet
  facet normal 0 -0.7 0.7
    outer loop
      vertex -1 -1 0
      vertex 1 -1 0
      vertex 0 0 1.5
    endloop
  endfacet
  facet normal 0.7 0 0.7
    outer loop
      vertex 1 -1 0
      vertex 1 1 0
      vertex 0 0 1.5
    endloop
  endfacet
  facet normal 0 0.7 0.7
    outer loop
      vertex 1 1 0
      vertex -1 1 0
      vertex 0 0 1.5
    endloop
  endfacet
endsolid test_pyramid
