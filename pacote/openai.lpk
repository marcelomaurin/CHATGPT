<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <Package Version="5">
    <PathDelim Value="\"/>
    <Name Value="openai"/>
    <Type Value="RunAndDesignTime"/>
    <Author Value="Marcelo Maurin Martins"/>
    <CompilerOptions>
      <Version Value="11"/>
      <PathDelim Value="\"/>
      <SearchPaths>
        <OtherUnitFiles Value=".."/>
        <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
      </SearchPaths>
    </CompilerOptions>
    <Description Value="Integration OpenAI, CHATGPT, this is not licensed for OpenAI. This is third-party."/>
    <License Value="OPEN SOURCE GPL3"/>
    <Files>
      <Item>
        <Filename Value="funcoes.pas"/>
        <UnitName Value="funcoes"/>
      </Item>
      <Item>
        <Filename Value="chatgpt.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="chatgpt"/>
      </Item>
      <Item>
        <Filename Value="neuralnetwork.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="neuralnetwork"/>
      </Item>
      <Item>
        <Filename Value="tokenizer.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="tokenizer"/>
      </Item>
      <Item>
        <Filename Value="aicodeassistant.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aicodeassistant"/>
      </Item>
      <Item>
        <Filename Value="aidatasetgenerator.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aidatasetgenerator"/>
      </Item>
      <Item>
        <Filename Value="pythonconnector.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="pythonconnector"/>
      </Item>
      <Item>
        <Filename Value="facedetection.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="facedetection"/>
      </Item>
      <Item>
        <Filename Value="yolodetect.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="yolodetect"/>
      </Item>
      <Item>
        <Filename Value="perceptron.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="perceptron"/>
      </Item>
      <Item>
        <Filename Value="sommap.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="sommap"/>
      </Item>
      <Item>
        <Filename Value="cnnclassifier.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="cnnclassifier"/>
      </Item>
      <Item>
        <Filename Value="lstmpredictor.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="lstmpredictor"/>
      </Item>
      <Item>
        <Filename Value="soundfilters.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="soundfilters"/>
      </Item>
      <Item>
        <Filename Value="imagefilters.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="imagefilters"/>
      </Item>
    </Files>
    <RequiredPkgs>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
    </RequiredPkgs>
    <UsageOptions>
      <UnitPath Value="$(PkgOutDir)"/>
    </UsageOptions>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
  </Package>
</CONFIG>
