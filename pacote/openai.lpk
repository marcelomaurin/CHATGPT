<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <Package Version="5">
    <PathDelim Value="\"/>
    <Name Value="openai"/>
    <Type Value="RunAndDesignTime"/>
    <Author Value="Marcelo Maurin Martins"/>
    <CompilerOptions>
