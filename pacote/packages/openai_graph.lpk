<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <Package Version="5">
    <PathDelim Value="\"/>
    <Name Value="openai_graph"/>
    <Type Value="RunAndDesignTime"/>
    <Author Value="Marcelo Maurin Martins"/>
    <CompilerOptions>
      <Version Value="11"/>
      <PathDelim Value="\"/>
      <SearchPaths>
        <OtherUnitFiles Value="..\AI Graph"/>
        <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
      </SearchPaths>
    </CompilerOptions>
    <Description Value="Lazarus AI Suite: Graph Classifier, factual dependency graph, route graph, and visualization components (TAIGraphMap, TAIDependencyGraph, TAIGraphStructuralAdapter, TAITrainingExporter, TAIDatasetAnalyzer, TAITrainingReport, TAIGraphVisualizer, TAIRouteGraph, TAIGeoJSONRouteImporter, TAIRouteSpeedProfile, TAIRouteCalculator, TAIRouteCityIndex)."/>
    <License Value="OPEN SOURCE GPL3"/>
    <Files>
      <Item>
        <Filename Value="..\AI Graph\aidependencygraph.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aidependencygraph"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\aigraphmap.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aigraphmap"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\aigraphstructuraladapter.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aigraphstructuraladapter"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\aitrainingexporter.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aitrainingexporter"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\aidatasetanalyzer.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aidatasetanalyzer"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\aitrainingreport.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aitrainingreport"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\aigraphvisualizer.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aigraphvisualizer"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\airoutegraph_types.pas"/>
        <UnitName Value="airoutegraph_types"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\airoutegraph_utils.pas"/>
        <UnitName Value="airoutegraph_utils"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\airoutegraph.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="airoutegraph"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\airoutespeedprofile.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="airoutespeedprofile"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\airoutecityindex.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="airoutecityindex"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\airoutecalculator.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="airoutecalculator"/>
      </Item>
      <Item>
        <Filename Value="..\AI Graph\aigeojsonrouteimporter.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aigeojsonrouteimporter"/>
      </Item>
    </Files>
    <RequiredPkgs>
      <Item>
        <PackageName Value="openai_core"/>
      </Item>
      <Item>
        <PackageName Value="openai_ml"/>
      </Item>
      <Item>
        <PackageName Value="openai_input"/>
      </Item>
      <Item>
        <PackageName Value="openai_output"/>
      </Item>
      <Item>
        <PackageName Value="openai_agent"/>
      </Item>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
    </RequiredPkgs>
    <UsageOptions>
      <UnitPath Value="$(PkgOutDir)"/>
    </UsageOptions>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
  </Package>
</CONFIG>
