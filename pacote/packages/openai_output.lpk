<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <Package Version="5">
    <PathDelim Value="\"/>
    <Name Value="openai_output"/>
    <Type Value="RunAndDesignTime"/>
    <Author Value="Marcelo Maurin Martins"/>
    <CompilerOptions>
      <Version Value="11"/>
      <PathDelim Value="\"/>
      <SearchPaths>
        <OtherUnitFiles Value="..\AI;..\AI Agent;..\AI Voice;..\AI Filtros Sonoros;..\AI Image;..\AI Schedule;..\AI Math;..\AI Input;..\AI Output;..\AI Graph;..\AI Graphic;..\AI Vision;.."/>
        <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
      </SearchPaths>
    </CompilerOptions>
    <Description Value="Lazarus AI Suite: Structured outputs, document generation (PDF/DOCX/XLSX/TXT) and POS printing."/>
    <License Value="OPEN SOURCE GPL3"/>
    <Files>
      <Item>
        <Filename Value="..\AI Output\aioutput.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aioutput"/>
      </Item>
      <Item>
        <Filename Value="..\AI Output\aioutput_docs.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aioutput_docs"/>
      </Item>
      <Item>
        <Filename Value="..\AI Output\aiwordtypes.pas"/>
        <UnitName Value="aiwordtypes"/>
      </Item>
      <Item>
        <Filename Value="..\AI Output\aiwordunits.pas"/>
        <UnitName Value="aiwordunits"/>
      </Item>
      <Item>
        <Filename Value="..\AI Output\aiwordpackage.pas"/>
        <UnitName Value="aiwordpackage"/>
      </Item>
      <Item>
        <Filename Value="..\AI Output\aiwordxml.pas"/>
        <UnitName Value="aiwordxml"/>
      </Item>
      <Item>
        <Filename Value="..\AI Output\aiwordrelationships.pas"/>
        <UnitName Value="aiwordrelationships"/>
      </Item>
      <Item>
        <Filename Value="..\AI Output\aiwordstyles.pas"/>
        <UnitName Value="aiwordstyles"/>
      </Item>
      <Item>
        <Filename Value="..\AI Output\aiwordobjects.pas"/>
        <UnitName Value="aiwordobjects"/>
      </Item>
      <Item>
        <Filename Value="..\AI Output\aiworddocument.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiworddocument"/>
      </Item>
      <Item>
        <Filename Value="..\AI Output\aiwordviewer.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiwordviewer"/>
      </Item>
    </Files>
    <RequiredPkgs>
      <Item>
        <PackageName Value="openai_core"/>
      </Item>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
    </RequiredPkgs>
    <UsageOptions>
      <UnitPath Value="$(PkgOutDir)"/>
    </UsageOptions>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
  </Package>
</CONFIG>
