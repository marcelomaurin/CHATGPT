<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <Package Version="5">
    <PathDelim Value="\"/>
    <Name Value="openai_input"/>
    <Type Value="RunAndDesignTime"/>
    <Author Value="Marcelo Maurin Martins"/>
    <CompilerOptions>
      <Version Value="11"/>
      <PathDelim Value="\"/>
      <SearchPaths>
        <OtherUnitFiles Value="..\AI Agent;..\AI Voice;..\AI Filtros Sonoros;..\AI Image;..\AI Schedule;..\AI Math;..\AI Input;..\AI Output;..\AI Graph;..\AI Graphic;..\AI Vision;.."/>
        <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
      </SearchPaths>
    </CompilerOptions>
    <Description Value="Lazarus AI Suite: Generic inputs, cameras, web servers, serial ports and Chromium integrations."/>
    <License Value="OPEN SOURCE GPL3"/>
    <Files>
      <Item>
        <Filename Value="..\AI Input\aiinput.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiinput"/>
      </Item>
      <Item>
        <Filename Value="..\AI Input\aicapturesource.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aicapturesource"/>
      </Item>
      <Item>
        <Filename Value="..\AI Input\aicapturesource_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Input\aiwebserver.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiwebserver"/>
      </Item>
      <Item>
        <Filename Value="..\AI Input\aisockets.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aisockets"/>
      </Item>
      <Item>
        <Filename Value="..\AI Input\aiserial.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiserial"/>
      </Item>
      <Item>
        <Filename Value="..\AI Input\aiemail.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiemail"/>
      </Item>
      <Item>
        <Filename Value="..\AI Input\aimessenger.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aimessenger"/>
      </Item>
      <Item>
        <Filename Value="..\AI Input\aichromiumbrowser.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aichromiumbrowser"/>
      </Item>
    </Files>
    <RequiredPkgs>
      <Item>
        <PackageName Value="CEF4Delphi_Lazarus"/>
      </Item>
      <Item>
        <PackageName Value="openai_core"/>
      </Item>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
    </RequiredPkgs>
    <UsageOptions>
      <UnitPath Value="$(PkgOutDir)"/>
    </UsageOptions>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
  </Package>
</CONFIG>
