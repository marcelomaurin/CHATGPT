<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <Package Version="5">
    <PathDelim Value="\"/>
    <Name Value="openai_vision"/>
    <Type Value="RunAndDesignTime"/>
    <Author Value="Marcelo Maurin Martins"/>
    <CompilerOptions>
      <Version Value="11"/>
      <PathDelim Value="\"/>
      <SearchPaths>
        <OtherUnitFiles Value="..\IA;..\IA Agent;..\IA Voice;..\IA Filtros Sonoros;..\IA Image;..\IA Schedulle;..\IA Math;..\IA Input;..\IA Output;..\IA Graph;..\AI Graphic;..\AI Vision;.."/>
        <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
      </SearchPaths>
    </CompilerOptions>
    <Description Value="Lazarus AI Suite: Computer Vision and OpenCV components (TAIOpenCV, TAICameraCapture, TAIFrameProcessor, TAIFaceTracker, TAIMotionTracker)."/>
    <License Value="OPEN SOURCE GPL3"/>
    <Files>
      <Item>
        <Filename Value="..\AI Vision\aiopencvruntime.pas"/>
        <UnitName Value="aiopencvruntime"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aiopencv.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiopencv"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aicamera_backend.pas"/>
        <UnitName Value="aicamera_backend"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aicamera_vfw.pas"/>
        <UnitName Value="aicamera_vfw"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aicamera_v4l2.pas"/>
        <UnitName Value="aicamera_v4l2"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aicameracapture.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aicameracapture"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aiframeprocessor.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiframeprocessor"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aifacetracker.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aifacetracker"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aimotiontracker.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aimotiontracker"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aiimageinfo.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiimageinfo"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aiframebuffer.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiframebuffer"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\ainativeimagefilter.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="ainativeimagefilter"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aiframediff.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiframediff"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aiimageinfo_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aiframebuffer_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\ainativeimagefilter_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Vision\aiframediff_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
    </Files>
    <RequiredPkgs>
      <Item>
        <PackageName Value="openai_core"/>
      </Item>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
    </RequiredPkgs>
    <UsageOptions>
      <UnitPath Value="$(PkgOutDir)"/>
    </UsageOptions>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
  </Package>
</CONFIG>
