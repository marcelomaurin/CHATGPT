<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <Package Version="5">
    <PathDelim Value="\"/>
    <Name Value="openai_simulation"/>
    <Type Value="RunAndDesignTime"/>
    <Author Value="Marcelo Maurin Martins"/>
    <CompilerOptions>
      <Version Value="11"/>
      <PathDelim Value="\"/>
      <SearchPaths>
        <OtherUnitFiles Value="..\AI Simulation;.."/>
        <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
      </SearchPaths>
    </CompilerOptions>
    <Description Value="Lazarus AI Suite: Simulation Components for cellular 2D grids, rules, engines, movement and visual rendering."/>
    <License Value="OPEN SOURCE GPL3"/>
    <Files>
      <Item>
        <Filename Value="..\AI Simulation\aigridcell.pas"/>
        <UnitName Value="aigridcell"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aigridworld.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aigridworld"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aigridbuffer.pas"/>
        <UnitName Value="aigridbuffer"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aisimentity.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aisimentity"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aientityfactory.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aientityfactory"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aisimulationengine.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aisimulationengine"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\airuleengine.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="airuleengine"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aitriggerengine.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aitriggerengine"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aimovementengine.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aimovementengine"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aievolutionengine.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aievolutionengine"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aisimulationstats.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aisimulationstats"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aigridrenderer2d.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aigridrenderer2d"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aiscenarioconfig.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiscenarioconfig"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aiscenariogenerator.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aiscenariogenerator"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aisimulationexporter.pas"/>
        <HasRegisterProc Value="True"/>
        <UnitName Value="aisimulationexporter"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aigridworld_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aisimentity_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aientityfactory_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aisimulationengine_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\airuleengine_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aitriggerengine_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aimovementengine_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aievolutionengine_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aisimulationstats_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aigridrenderer2d_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aiscenarioconfig_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aiscenariogenerator_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
      <Item>
        <Filename Value="..\AI Simulation\aisimulationexporter_icon.lrs"/>
        <Type Value="LRS"/>
      </Item>
    </Files>
    <RequiredPkgs>
      <Item>
        <PackageName Value="openai_core"/>
      </Item>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
    </RequiredPkgs>
    <UsageOptions>
      <UnitPath Value="$(PkgOutDir)"/>
    </UsageOptions>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
  </Package>
</CONFIG>
